{
  "name": "fas-cms",
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- cross-env NODE_ENV=development NETLIFY_DEV=1 astro dev --host localhost --port 4321 --strictPort",
    "dev:clean": "rimraf node_modules/.vite .astro && dotenv -e .env -- cross-env NODE_ENV=development NETLIFY_DEV=1 astro dev --host localhost --port 4321 --strictPort",
    "prebuild": "node scripts/netlify/prepare-gmc-service-account.cjs && node scripts/netlify/prepare-functions-internal.cjs",
    "postbuild": "node scripts/netlify/prepare-functions-internal.cjs",
    "build": "cross-env NODE_ENV=production astro build",
    "preview": "cross-env NODE_ENV=production astro preview",
    "lint": "eslint \"src/**/*.{js,ts,jsx,tsx}\"",
    "test": "yarn lint && yarn type-check",
    "test:unit": "vitest run",
    "cleanup:deps": "depcheck",
    "cleanup:files": "rimraf node_modules .astro dist build .cache .netlify .turbo .parcel-cache coverage",
    "type-check": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=1 BROWSERSLIST_IGNORE_OLD_DATA=1 astro check --minimumSeverity warning",
    "prepare": "husky install",
    "merchant:upload": "tsx scripts/merchant/upload-google-merchant-feed.ts",
    "stripe:sync": "tsx scripts/stripe/sync-products.ts",
    "resend-flow-check": "tsx scripts/resend-flow-check.ts",
    "firehose:test": "node scripts/firehose-monitor-fetch.js test",
    "firehose:ingest": "node scripts/firehose-monitor-fetch.js ingest",
    "firehose:cron:run": "tsx scripts/firehose-run-cron-local.ts",
    "astro:check": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=1 BROWSERSLIST_IGNORE_OLD_DATA=1 astro check --minimumSeverity warning",
    "audit:sanity-addons": "dotenv -e .env -- tsx src/scripts/audit-sanity-addons.ts",
    "audit:create-priority-list": "dotenv -e .env -- tsx src/scripts/create-migration-priority-list.ts",
    "env:check:netlify": "node ./scripts/check-env-unused.mjs --file .env",
    "env:check:local": "node ./scripts/check-env-unused.mjs --file .env.local",
    "env:sync": "node scripts/sync-env-to-netlify.js",
    "env:sync:dry": "node scripts/sync-env-to-netlify.js --dry-run",
    "env:sync:remove": "node scripts/sync-env-to-netlify.js --remove",
    "deploy:netlify": "node ./scripts/netlify-deploy.mjs",
    "deploy:netlify:skip-env-check": "node ./scripts/netlify-deploy.mjs --skip-env-check",
    "docs:check": "node ./scripts/docs-drift-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/api-smoke.spec.ts",
    "test:e2e:shop": "playwright test tests/e2e/shop.spec.ts",
    "test:e2e:checkout": "playwright test tests/e2e/checkout.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ci": "playwright test --reporter=github",
    "compliance:check": "npx tsx ../fas-sanity/scripts/compliance/fas-compliance-check.ts"
  },
  "depcheck": {
    "ignorePatterns": [
      ".eslintrc.cjs",
      "sanity/**",
      "sanity.json"
    ],
    "ignoreMatches": [
      "astro:content",
      "astro:middleware"
    ],
    "specials": [
      "typescript"
    ]
  },
  "lint-staged": {
    "*": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "20.x"
  },
  "resolutions": {
