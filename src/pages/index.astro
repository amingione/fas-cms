---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import * as sanity from '../lib/sanity-utils';
import type { Product } from '@/lib/sanity-utils';
import {
  attachMedusaPricingBySanityIdentity,
  listStoreProductsForPricing,
  resolveProductCalculatedPriceAmount
} from '@/lib/medusa-storefront-pricing';
import { centsToDollars } from '@/lib/pricing';
import HomepageHero from '@/components/homepage/HomepageHero.astro';
import FASHeroUltra from '@/components/hero/FASHeroUltra';
import FitmentSearch from '@/components/homepage/FitmentSearch.astro';
import BilletProductGrid from '@/components/homepage/BilletProductGrid.astro';
import PowerPackages from '@/components/homepage/PowerPackages.astro';
import CustomFabricationSection from '@/components/homepage/CustomFabricationSection.astro';
import ServicesStrip from '@/components/homepage/ServicesStrip.astro';
import VendorWholesaleSection from '@/components/homepage/VendorWholesaleSection.astro';
import HomepageFooter from '@/components/homepage/HomepageFooter.astro';
import EmailCaptureModal from '@components/EmailCaptureModal.tsx';
import StorefrontFaqSection from '@/components/storefront/StorefrontFaqSection.astro';

const siteOrigin = (() => {
  const candidate =
    (import.meta.env.PUBLIC_SITE_URL as string | undefined) || 'https://fasmotorsports.com';
  try {
    return new URL(candidate).origin;
  } catch {
    return 'https://fasmotorsports.com';
  }
})();

const canonicalHome = `${siteOrigin}/`;

const medusaProductsPromise = listStoreProductsForPricing().catch((error) => {
  console.error('[home] Failed to list Medusa pricing products', error);
  return [];
});

const featuredProductsPromise = sanity
  .fetchFeaturedProducts({ limit: 6, ttlSeconds: 180 })
  .catch((error) => {
    console.error('[home] Failed to fetch featured products', error);
    return [];
  });

const billetProductsPromise = sanity
  .fetchFilteredProducts({ categorySlug: 'billet-parts', pageSize: 4, sortBy: 'featured' })
  .catch((error) => {
    console.error('[home] Failed to fetch billet products', error);
    return [];
  });

const [medusaProducts, featuredProductsRaw, billetProductsRaw] =
  await Promise.all([
    medusaProductsPromise,
    featuredProductsPromise,
    billetProductsPromise,
  ]);

const attachPricing = <T extends Record<string, unknown>>(products: T[]) => {
  if (!Array.isArray(products) || products.length === 0 || medusaProducts.length === 0)
    return products;
  return attachMedusaPricingBySanityIdentity(products as any, medusaProducts) as T[];
};

const normalizeImageUrl = (product: Record<string, any>) => {
  const candidate =
    typeof product.imageUrl === 'string'
      ? product.imageUrl
      : Array.isArray(product.images)
        ? product.images[0]?.asset?.url || product.images[0]?.url
        : undefined;
  return sanity.normalizeSanityImageUrl(candidate) ?? candidate;
};

const normalizeProducts = (products: any[]) =>
  products.map((product) => ({ ...product, imageUrl: normalizeImageUrl(product) }));

const featuredProducts = attachPricing(
  normalizeProducts(Array.isArray(featuredProductsRaw) ? featuredProductsRaw : [])
);
const billetProducts = attachPricing(
  normalizeProducts(
    Array.isArray(billetProductsRaw) && billetProductsRaw.length > 0
      ? billetProductsRaw
      : featuredProducts.slice(0, 4)
  )
);
const schemaProducts = [...billetProducts].filter(Boolean);

const productSchemas = schemaProducts
  .map((product: Product | Record<string, any>, index) => {
    const name =
      (product as any).displayTitle ||
      (product as any).name ||
      (product as any).title ||
      'F.A.S. Motorsports Product';
    const slug =
      typeof (product as any).slug === 'string'
        ? (product as any).slug
        : (product as any).slug?.current;
    const priceCents = resolveProductCalculatedPriceAmount(product as any);
    const priceDollars = centsToDollars(priceCents ?? null);
    const priceValue = typeof priceDollars === 'number' ? priceDollars.toFixed(2) : undefined;
    const productUrl = slug ? `${canonicalHome}shop/${slug}` : canonicalHome;
    const image =
      typeof (product as any).imageUrl === 'string' ? (product as any).imageUrl : undefined;

    return {
      '@type': 'Product',
      '@id': `#homepage-product-${index + 1}`,
      name,
      image: image ? [image] : undefined,
      description:
        (product as any).description ||
        `${name} available through F.A.S. Motorsports with pricing resolved from the live storefront.`,
      brand: { '@type': 'Organization', name: 'F.A.S. Motorsports' },
      url: productUrl,
      offers: priceValue
        ? {
            '@type': 'Offer',
            priceCurrency: 'USD',
            price: priceValue,
            availability: 'https://schema.org/InStock',
            url: productUrl
          }
        : undefined
    };
  })
  .filter(Boolean);

const structuredDataGraph =
  productSchemas.length > 0
    ? {
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'ItemList',
            '@id': '#homepage-products',
            name: 'Homepage product highlights',
            numberOfItems: productSchemas.length,
            itemListElement: productSchemas.map((product: any, index) => ({
              '@type': 'ListItem',
              position: index + 1,
              item: { '@id': product['@id'] }
            }))
          },
          ...productSchemas
        ]
      }
    : null;

const homepageFaqEntries = [
  {
    question: 'How fast do orders ship from F.A.S. Motorsports?',
    answer:
      'Most in-stock parts ship quickly from our Florida facility. Install-only services are scheduled with the shop and do not ship like standard parts.'
  },
  {
    question: 'Do homepage product prices come from the real storefront?',
    answer:
      'Yes. The billet and package cards on the homepage are now rendered with live Medusa pricing attached server-side during the page build.'
  },
  {
    question: 'Can I combine parts and truck packages in one checkout?',
    answer:
      'Yes. Mixed carts are supported so you can buy individual parts alongside performance packages in one checkout flow.'
  },
  {
    question: 'Is the fitment search fully dynamic yet?',
    answer:
      'Not yet. The new homepage fitment block is static for now and can become a React island later if the make-to-model cascade needs client logic.'
  }
];

const homepageFaqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homepageFaqEntries.map((entry) => ({
    '@type': 'Question',
    name: entry.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.answer
    }
  }))
};
---

<BaseLayout
  title="Performance Parts, Wheels & Packages"
  description="F.A.S. Motorsports — premium performance upgrades, billet parts, custom fabrication, and wheel packages for Hellcat, Trackhawk, TRX and more."
  canonical={canonicalHome}
  ogImage="https://fasmotorsports.com/images/social/social-share.webp"
  hideFooter={true}
  hideBreadcrumbs={true}
  bodyClass="bg-dark text-white min-h-screen flex flex-col"
  mainClass="flex-1 w-full max-w-none px-0 pt-0"
  keywords={[
    'F.A.S. Motorsports',
    'Hellcat performance parts',
    'TRX packages',
    'billet supercharger parts',
    'custom fabrication',
    'performance wheel packages'
  ]}
>
  {
    structuredDataGraph && (
      <Fragment slot="head">
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredDataGraph)}
        />
      </Fragment>
    )
  }
  <Fragment slot="head">
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(homepageFaqStructuredData)}
    />
  </Fragment>

  <div class="homepage-redesign">
    <HomepageHero />
    <FASHeroUltra client:load />
    <FitmentSearch />
    <BilletProductGrid products={billetProducts} />
    <PowerPackages />
    <CustomFabricationSection />
    <ServicesStrip />
    <VendorWholesaleSection />

    <div class="homepage-shell" style="padding-bottom: 56px;">
      <StorefrontFaqSection
        title="Quick Answers Before You Buy"
        subtitle="The top storefront questions we hear from shoppers every week."
        items={homepageFaqEntries}
      />
    </div>

    <HomepageFooter />
    <EmailCaptureModal client:idle />
  </div>
</BaseLayout>
