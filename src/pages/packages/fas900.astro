---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { BUSINESS_PHONE_E164, BUSINESS_PHONE_NATIONAL } from '@/lib/nap';

const variants = [
  { platform: 'Charger & Challenger', price: '$9,999.00', slug: 'fas-900-package', note: 'Hellcat Platform' },
  { platform: 'Trackhawk / Durango SRT', price: '$9,999.00', slug: 'fas-900-package', note: 'Hellcat Platform' },
  { platform: 'RAM 1500 TRX', price: '$9,999.00', slug: 'fas-900-package-copy-e32083', note: 'Supercharged HEMI' },
];

const included = [
  { name: 'Pulley Upgrade Package', detail: 'Aggressive pulley combination tuned for 900 WHP peak output while maintaining predictable boost delivery.' },
  { name: 'Upgraded Fuel Injectors', detail: 'High-flow injectors sized to support the fueling demand of a 900 WHP calibration on 91–93 octane.' },
  { name: 'Pinned Crank Assembly', detail: 'Mechanical crank lock installed as standard — a non-negotiable reliability item at 900 WHP and beyond.' },
  { name: 'Performance Thermostat', detail: 'Lower-temp thermostat maintains optimal coolant temperature during extended high-output operation.' },
  { name: 'Full Custom Dyno Tune', detail: 'Calibration developed on FAS in-house AWD dynamometer to your specific vehicle. Verified against the 900 WHP target before release.' },
  { name: 'Installation Labor', detail: 'Complete professional installation at our Punta Gorda, FL facility. Every FAS900 build is documented on our validated build sheet.' },
];

const faqs = [
  {
    q: 'What does the FAS900 add over the FAS850?',
    a: 'The FAS900 uses the same reliability foundation as the FAS850 (injectors, pinned crank, thermostat) but targets 900 WHP through a more aggressive pulley combination and a recalibrated tune. The fuel system is upgraded to support the additional demand.',
  },
  {
    q: 'Does the FAS900 require any internal engine work?',
    a: 'No. The FAS900 is a supercharger-based external build. Rods, pistons, and heads are not included or required at this tier. At the FAS1000 level, internal work becomes part of the equation.',
  },
  {
    q: 'What fuel does the FAS900 run on?',
    a: '91–93 octane pump gas. E85 compatibility is available as an option — ask about the FAS900 E85 variant when you contact us.',
  },
  {
    q: 'Is the FAS900 a realistic daily driver?',
    a: 'Yes. The FAS900 maintains factory-level drivability for street use. The tune is developed to be clean and responsive, not just peak-power optimized. Thousands of miles on the street is realistic at this power level with proper maintenance.',
  },
];
---

<BaseLayout
  title="FAS900 Hellcat Supercharger | 900 WHP"
  description="The FAS900 delivers a 900 WHP build on the Hellcat platform with upgraded fuel injectors, pinned crank, pulley package, and full custom dyno tuning. Available for Charger, Challenger, Trackhawk, Durango SRT, and RAM TRX at $9,999."
  canonical="https://fasmotorsports.com/packages/fas900/"
  keywords={['FAS900 package', 'Hellcat 900 WHP', 'TRX 900 HP build', 'Trackhawk 900 HP', 'Hellcat 900 horsepower package', 'custom dyno tune Hellcat 900', 'FAS Motorsports FAS900']}
  bodyClass="bg-dark text-white min-h-screen flex flex-col"
  mainClass="flex-1 w-full max-w-none px-0 pt-0"
>

  <section class="pkg-hero" aria-label="FAS900 package hero">
    <div class="pkg-hero__noise" aria-hidden="true"></div>
    <div class="pkg-hero__inner site-container">
      <div class="pkg-hero__eyebrow">
        <span class="pkg-tier-badge">HIGH PERFORMANCE</span>
        <span class="pkg-tier-divider" aria-hidden="true">|</span>
        <span class="pkg-tier-label">FAS MOTORSPORTS</span>
      </div>
      <h1 class="pkg-hero__name">FAS<span class="pkg-hero__num">900</span></h1>
      <p class="pkg-hero__claim">900 Wheel Horsepower. The Perfect Balance.</p>
      <p class="pkg-hero__sub">
        The FAS900 is where serious performance meets real-world reliability. A full fuel system
        upgrade, pinned crank, aggressive pulley package, and a custom tune built for 900 WHP — all
        calibrated and verified on our in-house AWD dyno in Punta Gorda, FL. Still street-drivable.
        Still pump gas.
      </p>
      <div class="pkg-hero__cta-row">
        <a href="/shop/fas-900-package" class="btn-pkg-primary">Order Your Build</a>
        <a href="#variants" class="btn-pkg-ghost">Compare Platforms</a>
      </div>
    </div>
  </section>

  <div class="stat-bar" role="list" aria-label="FAS900 key specifications">
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">900</span>
      <span class="stat-bar__label">Wheel HP Target</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">$9,999</span>
      <span class="stat-bar__label">All Platforms</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">91–93</span>
      <span class="stat-bar__label">Octane — Pump Gas</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">Pinned</span>
      <span class="stat-bar__label">Crank Standard</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">AWD</span>
      <span class="stat-bar__label">In-House Dyno</span>
    </div>
  </div>

  <section class="pkg-section site-container" id="included" aria-labelledby="included-heading">
    <h2 class="pkg-section__heading" id="included-heading">What's Included</h2>
    <p class="pkg-section__sub">A complete performance build. Six components. One verified power target. All done in-house at FAS.</p>
    <ul class="included-grid" role="list">
      {included.map((item) => (
        <li class="included-card" role="listitem">
          <div class="included-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L8.333 13.333 3.333 8.333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <strong class="included-card__name">{item.name}</strong>
            <p class="included-card__detail">{item.detail}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="pkg-section pkg-section--dark site-container" id="variants" aria-labelledby="variants-heading">
    <h2 class="pkg-section__heading" id="variants-heading">Platform Variants &amp; Pricing</h2>
    <p class="pkg-section__sub">The FAS900 is $9,999 across all Hellcat platforms. Same components. Same power target. Same FAS standard.</p>
    <div class="variants-table-wrap table-wrap" role="region" aria-label="Platform variants">
      <table class="variants-table">
        <thead>
          <tr>
            <th scope="col">Platform</th>
            <th scope="col">Price</th>
            <th scope="col">Power Target</th>
            <th scope="col">Fuel</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody>
          {variants.map((v) => (
            <tr>
              <td>
                <strong>{v.platform}</strong>
                <small class="platform-note">{v.note}</small>
              </td>
              <td class="price-cell">{v.price}</td>
              <td>900 WHP</td>
              <td>91–93 Oct</td>
              <td>
                <a href={`/shop/${v.slug}`} class="btn-table-cta" aria-label={`Order FAS900 for ${v.platform}`}>
                  Order →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="variants-disclaimer">
      Vehicle not included. Installation service performed at our Punta Gorda, FL facility.
      Modifying your vehicle may affect the factory warranty.
      <a href="/packages/fas850" class="text-link">← FAS850</a> &nbsp;·&nbsp;
      <a href="/packages/fas1000" class="text-link">FAS1000 →</a>
    </p>
  </section>

  <!-- ── FAS900 vs FAS1000 COMPARISON ─────────────────────── -->
  <section class="pkg-section site-container" aria-labelledby="compare-heading">
    <h2 class="pkg-section__heading" id="compare-heading">FAS900 vs. FAS1000 — Know the Difference</h2>
    <p class="pkg-section__sub">Both tiers are proven builds. The right choice depends on your goals, budget, and how far you want to push the platform.</p>
    <div class="compare-grid">
      <div class="compare-col compare-col--active" aria-label="FAS900 comparison column">
        <div class="compare-col__header">
          <span class="compare-col__tier">FAS900</span>
          <span class="compare-col__price">$9,999</span>
        </div>
        <ul class="compare-col__list" role="list">
          <li>900 WHP</li>
          <li>Pulley + injectors + pinned crank</li>
          <li>Performance thermostat</li>
          <li>Full custom dyno tune</li>
          <li>Pump gas (91–93 octane)</li>
          <li>Street drivable</li>
          <li>No internal engine work</li>
          <li>External build only</li>
        </ul>
      </div>
      <div class="compare-col" aria-label="FAS1000 comparison column">
        <div class="compare-col__header">
          <span class="compare-col__tier">FAS1000</span>
          <span class="compare-col__price">$16,999+</span>
        </div>
        <ul class="compare-col__list" role="list">
          <li>1000+ WHP</li>
          <li>Race ported supercharger</li>
          <li>108mm throttle body</li>
          <li>Upgraded fuel system</li>
          <li>Longtube headers</li>
          <li>E85 conversion</li>
          <li>Full custom dyno tune</li>
          <li>Track and street build</li>
        </ul>
        <a href="/packages/fas1000" class="compare-col__link">View FAS1000 →</a>
      </div>
    </div>
  </section>

  <section class="pkg-section pkg-section--dark site-container" aria-labelledby="upgrade-heading">
    <h2 class="pkg-section__heading" id="upgrade-heading">The FAS Performance Ladder</h2>
    <nav class="upgrade-ladder" aria-label="Performance package tiers">
      <a href="/packages/fas800" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS800</span>
        <span class="upgrade-rung__hp">800 WHP</span>
        <span class="upgrade-rung__tag">Pulley / ECU / Tune</span>
      </a>
      <a href="/packages/fas850" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS850</span>
        <span class="upgrade-rung__hp">850 WHP</span>
        <span class="upgrade-rung__tag">+ Injectors / Pinned Crank</span>
      </a>
      <a href="/packages/fas900" class="upgrade-rung upgrade-rung--active" aria-current="page">
        <span class="upgrade-rung__tier">FAS900</span>
        <span class="upgrade-rung__hp">900 WHP</span>
        <span class="upgrade-rung__tag">Current</span>
      </a>
      <a href="/packages/fas1000" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS1000</span>
        <span class="upgrade-rung__hp">1000+ WHP</span>
        <span class="upgrade-rung__tag">Race Ported SC / Headers / E85</span>
      </a>
      <a href="/packages/fas-1x" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS 1X</span>
        <span class="upgrade-rung__hp">1200–1500 HP</span>
        <span class="upgrade-rung__tag">Contact for Pricing</span>
      </a>
      <a href="/packages/fas-2x" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS 2X</span>
        <span class="upgrade-rung__hp">1600+ HP</span>
        <span class="upgrade-rung__tag">Contact for Pricing</span>
      </a>
    </nav>
  </section>

  <section class="pkg-section site-container" aria-labelledby="faq-heading">
    <h2 class="pkg-section__heading" id="faq-heading">Common Questions</h2>
    <dl class="pkg-faq">
      {faqs.map((faq) => (
        <div class="pkg-faq__entry">
          <dt class="pkg-faq__q">{faq.q}</dt>
          <dd class="pkg-faq__a">{faq.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="pkg-cta-final" aria-labelledby="cta-heading">
    <div class="site-container">
      <h2 class="pkg-cta-final__heading" id="cta-heading">Nine Hundred Wheel Horsepower.</h2>
      <p class="pkg-cta-final__sub">The FAS900 is $9,999 across all Hellcat platforms. Verified on our in-house dyno. Every car. Every time.</p>
      <div class="pkg-cta-final__row">
        <a href="/shop/fas-900-package" class="btn-pkg-primary btn-pkg-primary--large">Order the FAS900</a>
        <a href={`tel:${BUSINESS_PHONE_E164}`} class="btn-pkg-ghost">Call {BUSINESS_PHONE_NATIONAL}</a>
      </div>
      <address class="pkg-cta-final__address">
        FAS Motorsports · 6161 Riverside Dr, Punta Gorda, FL 33982 · Mon–Fri 9AM–5PM
      </address>
    </div>
  </section>

</BaseLayout>

<style>
.pkg-hero {
  position: relative;
  background: linear-gradient(160deg, #0a0202 0%, #080808 55%, #0d0303 100%);
  border-bottom: 1px solid var(--red-border);
  padding: clamp(80px, 12vw, 140px) 0 clamp(56px, 8vw, 96px);
  overflow: hidden;
}
.pkg-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(196,18,24,0.14) 0%, transparent 70%);
  pointer-events: none;
}
.pkg-hero__noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none; opacity: 0.4;
}
.pkg-hero__inner { position: relative; z-index: 1; }
.pkg-hero__eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
.pkg-tier-badge { font-family: var(--font-label); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); border: 1px solid var(--red-border); padding: 3px 10px; border-radius: 2px; }
.pkg-tier-divider { color: var(--border-strong); font-size: 0.75rem; }
.pkg-tier-label { font-family: var(--font-label); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); }
.pkg-hero__name { font-family: var(--font-display); font-size: clamp(3.5rem, 10vw, 7rem); line-height: 0.9; letter-spacing: -0.02em; color: var(--text-primary); margin: 0 0 12px; text-transform: uppercase; }
.pkg-hero__num { color: var(--red); }
.pkg-hero__claim { font-family: var(--font-label); font-size: clamp(1rem, 2.5vw, 1.35rem); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--amber); margin: 0 0 20px; }
.pkg-hero__sub { font-family: var(--font-body); font-size: clamp(0.95rem, 1.5vw, 1.05rem); color: var(--text-secondary); max-width: 640px; line-height: 1.65; margin: 0 0 36px; }
.pkg-hero__cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
.stat-bar { background: var(--bg-surface); border-bottom: 1px solid var(--border-subtle); display: flex; flex-wrap: wrap; justify-content: center; }
.stat-bar__item { display: flex; flex-direction: column; align-items: center; padding: 20px 28px; flex: 1; min-width: 120px; }
.stat-bar__val { font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 1.9rem); color: var(--red); line-height: 1; }
.stat-bar__label { font-family: var(--font-label); font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-top: 4px; text-align: center; }
.stat-bar__sep { width: 1px; background: var(--border-subtle); align-self: stretch; }
.pkg-section { padding: clamp(56px, 8vw, 96px) 0; }
.pkg-section--dark { background: var(--bg-surface); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
.pkg-section__heading { font-family: var(--font-display); font-size: clamp(1.5rem, 3.5vw, 2.4rem); color: var(--text-primary); letter-spacing: 0.02em; text-transform: uppercase; margin: 0 0 10px; }
.pkg-section__sub { font-family: var(--font-body); font-size: 0.97rem; color: var(--text-secondary); max-width: 600px; margin: 0 0 40px; line-height: 1.65; }
.included-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; list-style: none; padding: 0; margin: 0; }
.included-card { display: flex; gap: 14px; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 4px; padding: 20px; transition: border-color var(--dur-fast) var(--ease-out); }
.included-card:hover { border-color: var(--red-border); }
.included-card__icon { flex-shrink: 0; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--red-dim); border: 1px solid var(--red-border); border-radius: 50%; color: var(--red); }
.included-card__name { display: block; font-family: var(--font-label); font-size: 0.88rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-primary); margin-bottom: 4px; }
.included-card__detail { font-family: var(--font-body); font-size: 0.84rem; color: var(--text-secondary); line-height: 1.55; margin: 0; }
.variants-table-wrap { margin-bottom: 20px; }
.variants-table { width: 100%; border-collapse: collapse; font-family: var(--font-body); font-size: 0.9rem; }
.variants-table th { font-family: var(--font-label); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); background: var(--bg-overlay); padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-default); }
.variants-table td { padding: 14px 16px; border-bottom: 1px solid var(--border-subtle); color: var(--text-secondary); vertical-align: middle; }
.variants-table td strong { color: var(--text-primary); }
.variants-table tr:hover td { background: rgba(196,18,24,0.04); }
.price-cell { font-family: var(--font-display); font-size: 1rem; color: var(--text-primary) !important; }
.platform-note { display: block; font-size: 0.75rem; color: var(--text-muted); font-weight: 400; font-family: var(--font-body); }
.btn-table-cta { font-family: var(--font-label); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red); text-decoration: none; border: 1px solid var(--red-border); padding: 6px 14px; border-radius: 2px; white-space: nowrap; transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out); }
.btn-table-cta:hover { background: var(--red); color: #fff; }
.variants-disclaimer { font-family: var(--font-body); font-size: 0.8rem; color: var(--text-muted); line-height: 1.55; margin: 0; }
.text-link { color: var(--red); text-decoration: underline; }
/* COMPARE GRID */
.compare-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
.compare-col { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 4px; padding: 28px; }
.compare-col--active { border-color: var(--red); background: var(--red-dim); }
.compare-col__header { margin-bottom: 20px; }
.compare-col__tier { display: block; font-family: var(--font-display); font-size: 1.3rem; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.05em; }
.compare-col--active .compare-col__tier { color: var(--red); }
.compare-col__price { font-family: var(--font-label); font-size: 0.88rem; font-weight: 700; color: var(--amber); letter-spacing: 0.08em; }
.compare-col__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; font-family: var(--font-body); font-size: 0.88rem; color: var(--text-secondary); }
.compare-col__list li::before { content: '→ '; color: var(--red); font-family: var(--font-label); }
.compare-col__link { display: inline-block; margin-top: 20px; font-family: var(--font-label); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red); text-decoration: none; border-bottom: 1px solid var(--red-border); padding-bottom: 2px; }
.upgrade-ladder { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; }
.upgrade-rung { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 4px; text-decoration: none; transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out); }
.upgrade-rung:hover { border-color: var(--red-border); background: var(--bg-overlay); }
.upgrade-rung--active { border-color: var(--red); background: var(--red-dim); }
.upgrade-rung__tier { font-family: var(--font-display); font-size: 1rem; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.05em; }
.upgrade-rung--active .upgrade-rung__tier { color: var(--red); }
.upgrade-rung__hp { font-family: var(--font-label); font-size: 0.85rem; font-weight: 700; color: var(--amber); letter-spacing: 0.05em; }
.upgrade-rung__tag { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-muted); line-height: 1.3; }
.pkg-faq { display: flex; flex-direction: column; gap: 0; }
.pkg-faq__entry { padding: 24px 0; border-bottom: 1px solid var(--border-subtle); }
.pkg-faq__entry:last-child { border-bottom: none; }
.pkg-faq__q { font-family: var(--font-label); font-size: 0.97rem; font-weight: 700; letter-spacing: 0.04em; color: var(--text-primary); text-transform: uppercase; margin-bottom: 8px; }
.pkg-faq__a { font-family: var(--font-body); font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; margin: 0; }
.pkg-cta-final { background: linear-gradient(160deg, #100202 0%, #0a0000 100%); border-top: 1px solid var(--red-border); padding: clamp(64px, 10vw, 112px) 0; text-align: center; }
.pkg-cta-final__heading { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.04em; margin: 0 0 12px; }
.pkg-cta-final__sub { font-family: var(--font-body); font-size: 1rem; color: var(--text-secondary); max-width: 520px; margin: 0 auto 36px; line-height: 1.65; }
.pkg-cta-final__row { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-bottom: 28px; }
.pkg-cta-final__address { font-family: var(--font-body); font-size: 0.8rem; font-style: normal; color: var(--text-muted); }
.btn-pkg-primary { font-family: var(--font-label); font-size: 0.88rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; background: var(--red); color: #fff; padding: 14px 32px; border-radius: 2px; display: inline-flex; align-items: center; transition: background var(--dur-fast) var(--ease-out); }
