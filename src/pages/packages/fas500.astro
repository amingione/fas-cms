---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { BUSINESS_PHONE_E164, BUSINESS_PHONE_NATIONAL } from '@/lib/nap';

const variants = [
  { platform: 'Ford F-150 (2018+ EcoBoost 3.5L)', price: '$7,499.00', slug: 'fas500-f150' },
];

const included = [
  { name: 'FAS-Spec Twin 54mm Turbo System', detail: 'Purpose-built twin turbochargers sized for street reliability and dyno-proven 600 WHP output on the EcoBoost 3.5L platform.' },
  { name: 'Air-to-Air Intercooler + Stainless Plumbing', detail: 'Full front-mount intercooler with stainless charge pipes for consistent intake temps under sustained boost.' },
  { name: 'Upgraded Low-Side Fuel Pump', detail: 'High-flow in-tank pump upgrade to support the increased fuel demand of the turbo system on pump gas.' },
  { name: 'HP Tuners Calibration', detail: 'Custom HP Tuners calibration developed on our in-house AWD dynamometer. Optimized for 91/93 octane. Datalogs reviewed before vehicle release.' },
  { name: 'Installation Labor', detail: 'Complete installation at our Punta Gorda, FL facility by FAS technicians. No outside shops. No shortcuts.' },
];

const faqs = [
  {
    q: 'What year and engine F-150 does this fit?',
    a: 'The FAS500 is built for 2018+ Ford F-150 trucks with the EcoBoost 3.5L engine. If you have a different year or engine variant, contact us before ordering to confirm compatibility.',
  },
  {
    q: 'Does the FAS500 require E85 or race fuel?',
    a: 'No. The FAS500 is tuned and verified on 91–93 octane pump gas. No E85 fuel system modifications are required at this tier.',
  },
  {
    q: 'Is this a parts kit I install myself or a full service?',
    a: 'This is a complete installation service. You bring your F-150 to our shop in Punta Gorda, FL — we handle the full build, calibration, and dyno verification. No DIY required.',
  },
  {
    q: 'How long does the build take?',
    a: 'Most FAS500 builds complete within 2–3 business days. We will confirm a timeline when you schedule your build slot.',
  },
  {
    q: 'Will this affect my factory powertrain warranty?',
    a: 'Modifying your vehicle may affect factory warranty coverage. FAS cannot speak to the specific terms of your Ford warranty. We recommend reviewing your warranty documentation before proceeding.',
  },
];
---

<BaseLayout
  title="FAS500 | 600 WHP F-150 Turbo Build"
  description="The FAS500 delivers a proven 600 WHP turbo build for the 2018+ Ford F-150 EcoBoost 3.5L. Includes FAS twin 54mm turbo system, air-to-air intercooler, fuel pump upgrade, and full custom HP Tuners calibration. Installed and dyno-verified at our Punta Gorda, FL facility."
  canonical="https://fasmotorsports.com/packages/fas500/"
  keywords={['FAS500 package', 'Ford F-150 600 WHP', 'F-150 EcoBoost turbo upgrade', 'F-150 performance package', 'F-150 twin turbo install', 'HP Tuners F-150 tune', 'FAS Motorsports truck build']}
  bodyClass="bg-dark text-white min-h-screen flex flex-col"
  mainClass="flex-1 w-full max-w-none px-0 pt-0"
>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="pkg-hero" aria-label="FAS500 package hero">
    <div class="pkg-hero__noise" aria-hidden="true"></div>
    <div class="pkg-hero__inner site-container">
      <div class="pkg-hero__eyebrow">
        <span class="pkg-tier-badge">TRUCK PERFORMANCE</span>
        <span class="pkg-tier-divider" aria-hidden="true">|</span>
        <span class="pkg-tier-label">FAS MOTORSPORTS</span>
      </div>
      <h1 class="pkg-hero__name">FAS<span class="pkg-hero__num">500</span></h1>
      <p class="pkg-hero__claim">600 Wheel Horsepower. Twin Turbos. Still Drives to Work.</p>
      <p class="pkg-hero__sub">
        The FAS500 takes the 2018+ Ford F-150 EcoBoost 3.5L and turns it into a 600 WHP daily
        driver — on pump gas, on the street, with the same in-house dyno verification we apply to
        every package we build. Twin 54mm turbos, full intercooler, custom HP Tuners calibration.
        Everything done at our Punta Gorda facility. Nothing farmed out.
      </p>
      <div class="pkg-hero__cta-row">
        <a href="/contact" class="btn-pkg-primary">Schedule Your Build</a>
        <a href="#variants" class="btn-pkg-ghost">See Pricing</a>
      </div>
    </div>
  </section>

  <!-- ── POWER STAT BAR ───────────────────────────────────── -->
  <div class="stat-bar" role="list" aria-label="FAS500 key specifications">
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">600</span>
      <span class="stat-bar__label">Wheel HP Target</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">91–93</span>
      <span class="stat-bar__label">Octane — Pump Gas</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">Twin</span>
      <span class="stat-bar__label">54mm FAS Turbos</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">AWD</span>
      <span class="stat-bar__label">In-House Dyno</span>
    </div>
    <div class="stat-bar__sep" aria-hidden="true"></div>
    <div class="stat-bar__item" role="listitem">
      <span class="stat-bar__val">PGD, FL</span>
      <span class="stat-bar__label">Installation Facility</span>
    </div>
  </div>

  <!-- ── WHAT'S INCLUDED ──────────────────────────────────── -->
  <section class="pkg-section site-container" id="included" aria-labelledby="included-heading">
    <h2 class="pkg-section__heading" id="included-heading">What's Included</h2>
    <p class="pkg-section__sub">Every FAS500 build follows the same validated build sheet. Same parts, same process, same dyno standard — every truck, every time.</p>
    <ul class="included-grid" role="list">
      {included.map((item) => (
        <li class="included-card" role="listitem">
          <div class="included-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16.667 5L8.333 13.333 3.333 8.333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <strong class="included-card__name">{item.name}</strong>
            <p class="included-card__detail">{item.detail}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ── PLATFORM VARIANTS ────────────────────────────────── -->
  <section class="pkg-section pkg-section--dark site-container" id="variants" aria-labelledby="variants-heading">
    <h2 class="pkg-section__heading" id="variants-heading">Platform &amp; Pricing</h2>
    <p class="pkg-section__sub">The FAS500 is purpose-built for the 2018+ Ford F-150 EcoBoost 3.5L. Contact us to confirm compatibility with your specific build before ordering.</p>
    <div class="variants-table-wrap table-wrap" role="region" aria-label="Platform variants">
      <table class="variants-table">
        <thead>
          <tr>
            <th scope="col">Platform</th>
            <th scope="col">Price</th>
            <th scope="col">Power Target</th>
            <th scope="col">Fuel</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody>
          {variants.map((v) => (
            <tr>
              <td><strong>{v.platform}</strong></td>
              <td class="price-cell">{v.price}</td>
              <td>600 WHP</td>
              <td>91–93 Oct</td>
              <td>
                <a href="/contact" class="btn-table-cta" aria-label={`Schedule FAS500 build for ${v.platform}`}>
                  Schedule →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="variants-disclaimer">
      <strong>Note:</strong> Vehicle not included. Installation service requires vehicle drop-off at our Punta Gorda, FL facility.
      Modifying your vehicle may affect factory warranty. <a href="/packages" class="text-link">Browse all packages →</a>
    </p>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────── -->
  <section class="pkg-section site-container" id="process" aria-labelledby="process-heading">
    <h2 class="pkg-section__heading" id="process-heading">The Build Process</h2>
    <p class="pkg-section__sub">From intake manifold to dyno sheet — every FAS500 build is handled start to finish at our Punta Gorda facility.</p>
    <ol class="process-steps" role="list">
      <li class="process-step">
        <span class="process-step__num" aria-hidden="true">01</span>
        <div>
          <strong class="process-step__title">Schedule &amp; Drop Off</strong>
          <p class="process-step__body">Contact FAS to confirm your F-150 is compatible and lock in a build slot. Drop your truck at 6161 Riverside Dr, Punta Gorda, FL 33982.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-step__num" aria-hidden="true">02</span>
        <div>
          <strong class="process-step__title">Baseline Dyno Pull</strong>
          <p class="process-step__body">Stock baseline numbers are logged on our AWD dynamometer before any parts go on. You see exactly where you started.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-step__num" aria-hidden="true">03</span>
        <div>
          <strong class="process-step__title">Full Turbo System Installation</strong>
          <p class="process-step__body">FAS-spec twin 54mm turbos, full air-to-air intercooler with stainless plumbing, and upgraded low-side fuel pump installed by FAS technicians using our validated F-150 build sheet.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-step__num" aria-hidden="true">04</span>
        <div>
          <strong class="process-step__title">HP Tuners Calibration</strong>
          <p class="process-step__body">Custom calibration developed specifically for your truck on our in-house dyno. Not a generic file — tuned to your vehicle's individual response, fuel system, and ambient conditions on 91/93 octane.</p>
        </div>
      </li>
      <li class="process-step">
        <span class="process-step__num" aria-hidden="true">05</span>
        <div>
          <strong class="process-step__title">Verification &amp; Release</strong>
          <p class="process-step__body">Final dyno pulls confirm 600 WHP target. Datalogs reviewed. Your truck is not leaving until the numbers are right.</p>
        </div>
      </li>
    </ol>
  </section>

  <!-- ── TRUCK PLATFORM SECTION ────────────────────────────── -->
  <section class="pkg-section pkg-section--dark site-container" aria-labelledby="platform-heading">
    <h2 class="pkg-section__heading" id="platform-heading">Other FAS Platforms</h2>
    <p class="pkg-section__sub">The FAS500 is our dedicated F-150 program. If you run a Hellcat platform or RAM TRX, we have a full performance ladder waiting.</p>
    <nav class="upgrade-ladder" aria-label="FAS platform packages">
      <a href="/packages/fas500" class="upgrade-rung upgrade-rung--active" aria-current="page">
        <span class="upgrade-rung__tier">FAS500</span>
        <span class="upgrade-rung__hp">600 WHP</span>
        <span class="upgrade-rung__tag">Ford F-150 EcoBoost · Current</span>
      </a>
      <a href="/packages/fas800" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS800</span>
        <span class="upgrade-rung__hp">800 WHP</span>
        <span class="upgrade-rung__tag">Hellcat / TRX · Entry</span>
      </a>
      <a href="/packages/fas850" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS850</span>
        <span class="upgrade-rung__hp">850 WHP</span>
        <span class="upgrade-rung__tag">Hellcat · Injectors / Pinned Crank</span>
      </a>
      <a href="/packages/fas900" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS900</span>
        <span class="upgrade-rung__hp">900 WHP</span>
        <span class="upgrade-rung__tag">Hellcat · Fuel System</span>
      </a>
      <a href="/packages/fas1000" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS1000</span>
        <span class="upgrade-rung__hp">1000+ WHP</span>
        <span class="upgrade-rung__tag">Hellcat / TRX · Race SC / Headers / E85</span>
      </a>
      <a href="/packages/fas-1x" class="upgrade-rung">
        <span class="upgrade-rung__tier">FAS 1X</span>
        <span class="upgrade-rung__hp">1200–1500 HP</span>
        <span class="upgrade-rung__tag">Contact for Pricing</span>
      </a>
    </nav>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────── -->
  <section class="pkg-section site-container" aria-labelledby="faq-heading">
    <h2 class="pkg-section__heading" id="faq-heading">Common Questions</h2>
    <dl class="pkg-faq">
      {faqs.map((faq) => (
        <div class="pkg-faq__entry">
          <dt class="pkg-faq__q">{faq.q}</dt>
          <dd class="pkg-faq__a">{faq.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="pkg-cta-final" aria-labelledby="cta-heading">
    <div class="site-container">
      <h2 class="pkg-cta-final__heading" id="cta-heading">Ready to Build?</h2>
      <p class="pkg-cta-final__sub">Schedule your FAS500 build today. Every truck leaves our shop dyno-verified to 600 WHP on pump gas.</p>
      <div class="pkg-cta-final__row">
        <a href="/contact" class="btn-pkg-primary btn-pkg-primary--large">Schedule Your FAS500 Build</a>
        <a href={`tel:${BUSINESS_PHONE_E164}`} class="btn-pkg-ghost">Call {BUSINESS_PHONE_NATIONAL}</a>
      </div>
      <address class="pkg-cta-final__address">
        FAS Motorsports · 6161 Riverside Dr, Punta Gorda, FL 33982 · Mon–Fri 9AM–5PM
      </address>
    </div>
  </section>

</BaseLayout>

<style>
/* ──────────────────────────────────────────────────────────
   PACKAGE PAGE DESIGN SYSTEM
   Inherits from fas-theme2.css tokens
────────────────────────────────────────────────────────── */

/* HERO */
.pkg-hero {
  position: relative;
  background: linear-gradient(160deg, #0a0202 0%, #080808 55%, #0d0303 100%);
  border-bottom: 1px solid var(--red-border);
  padding: clamp(80px, 12vw, 140px) 0 clamp(56px, 8vw, 96px);
  overflow: hidden;
}
.pkg-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 0%, rgba(196,18,24,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.pkg-hero__noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  opacity: 0.4;
}
.pkg-hero__inner { position: relative; z-index: 1; }
.pkg-hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}
.pkg-tier-badge {
  font-family: var(--font-label);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red);
  border: 1px solid var(--red-border);
  padding: 3px 10px;
  border-radius: 2px;
}
.pkg-tier-divider { color: var(--border-strong); font-size: 0.75rem; }
.pkg-tier-label {
  font-family: var(--font-label);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.pkg-hero__name {
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 10vw, 7rem);
  line-height: 0.9;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  margin: 0 0 12px;
  text-transform: uppercase;
}
.pkg-hero__num { color: var(--red); }
.pkg-hero__claim {
  font-family: var(--font-label);
  font-size: clamp(1rem, 2.5vw, 1.35rem);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--amber);
  margin: 0 0 20px;
}
.pkg-hero__sub {
  font-family: var(--font-body);
  font-size: clamp(0.95rem, 1.5vw, 1.05rem);
  color: var(--text-secondary);
  max-width: 640px;
  line-height: 1.65;
  margin: 0 0 36px;
}
.pkg-hero__cta-row { display: flex; flex-wrap: wrap; gap: 12px; }

/* STAT BAR */
.stat-bar {
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-subtle);
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0;
  overflow: hidden;
}
.stat-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 28px;
  flex: 1;
  min-width: 120px;
}
.stat-bar__val {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 3vw, 1.9rem);
  color: var(--red);
  line-height: 1;
  letter-spacing: -0.01em;
}
.stat-bar__label {
  font-family: var(--font-label);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 4px;
  text-align: center;
}
.stat-bar__sep {
  width: 1px;
  background: var(--border-subtle);
  align-self: stretch;
}

/* SECTIONS */
.pkg-section {
  padding: clamp(56px, 8vw, 96px) 0;
}
.pkg-section--dark {
  background: var(--bg-surface);
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
}
.pkg-section__heading {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3.5vw, 2.4rem);
  color: var(--text-primary);
  letter-spacing: 0.02em;
  text-transform: uppercase;
  margin: 0 0 10px;
}
.pkg-section__sub {
  font-family: var(--font-body);
  font-size: 0.97rem;
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 0 40px;
  line-height: 1.65;
}

/* INCLUDED GRID */
.included-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  list-style: none;
  padding: 0;
  margin: 0;
}
.included-card {
  display: flex;
  gap: 14px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: 4px;
  padding: 20px;
  transition: border-color var(--dur-fast) var(--ease-out);
}
.included-card:hover { border-color: var(--red-border); }
.included-card__icon {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--red-dim);
  border: 1px solid var(--red-border);
  border-radius: 50%;
  color: var(--red);
}
.included-card__name {
  display: block;
  font-family: var(--font-label);
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-primary);
  margin-bottom: 4px;
}
.included-card__detail {
  font-family: var(--font-body);
  font-size: 0.84rem;
  color: var(--text-secondary);
  line-height: 1.55;
  margin: 0;
}

/* VARIANTS TABLE */
.variants-table-wrap { margin-bottom: 20px; }
.variants-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-body);
  font-size: 0.9rem;
}
.variants-table th {
  font-family: var(--font-label);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  background: var(--bg-overlay);
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--border-default);
}
.variants-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-subtle);
  color: var(--text-secondary);
  vertical-align: middle;
}
.variants-table td strong { color: var(--text-primary); }
.variants-table tr:hover td { background: rgba(196,18,24,0.04); }
.price-cell {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--text-primary) !important;
}
.btn-table-cta {
  font-family: var(--font-label);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
  text-decoration: none;
  border: 1px solid var(--red-border);
  padding: 6px 14px;
  border-radius: 2px;
  white-space: nowrap;
  transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
}
.btn-table-cta:hover {
  background: var(--red);
  color: #fff;
}
.variants-disclaimer {
  font-family: var(--font-body);
  font-size: 0.8rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin: 0;
}
.text-link { color: var(--red); text-decoration: underline; }

/* PROCESS STEPS */
.process-steps {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  counter-reset: none;
}
.process-step {
  display: flex;
  gap: 24px;
  padding: 28px 0;
  border-bottom: 1px solid var(--border-subtle);
  align-items: flex-start;
}
.process-step:last-child { border-bottom: none; }
.process-step__num {
  font-family: var(--font-display);
  font-size: 2rem;
  color: var(--red);
  opacity: 0.4;
  line-height: 1;
  flex-shrink: 0;
  min-width: 48px;
}
.process-step__title {
  display: block;
  font-family: var(--font-label);
  font-size: 0.92rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-primary);
  margin-bottom: 6px;
}
.process-step__body {
  font-family: var(--font-body);
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.65;
  margin: 0;
}

/* UPGRADE / PLATFORM LADDER */
.upgrade-ladder {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 8px;
}
.upgrade-rung {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 18px 20px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: 4px;
  text-decoration: none;
  transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
}
.upgrade-rung:hover { border-color: var(--red-border); background: var(--bg-overlay); }
.upgrade-rung--active {
  border-color: var(--red);
