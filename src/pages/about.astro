---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadPageDoc, inlineFieldAttrs, inlineObjectId } from '@lib/content';
import { serializeJsonLd } from '@lib/utils';
import img_frank_mingione_i from '@/assets/images/Frank-Mingione-I.webp';
import img_frank_mingione_ii from '@/assets/images/Frank-Mingione-II.webp';
import img_fas_team_testing_day from '@/assets/images/FAS-Team-Testing-Day.webp';

const pageDoc: any = await loadPageDoc('about');
const requestUrl = new URL(Astro.request.url);
requestUrl.search = '';
requestUrl.hash = '';
const canonical = requestUrl.toString();

const pageTitle = 'About F.A.S. Motorsports';
const pageDescription =
  'Discover the F.A.S. Motorsports legacy in Punta Gorda, FL—family-built racers delivering billet parts, custom fabrication, and high-performance installs.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  name: 'F.A.S. Motorsports',
  url: canonical,
  logo: 'https://fasmotorsports.com/logo/fas-logo500.webp',
  image: 'https://fasmotorsports.com/images/FAS-Team-Testing-Day.webp',
  description: pageDescription,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6161 Riverside Dr',
    addressLocality: 'Punta Gorda',
    addressRegion: 'FL',
    postalCode: '33982',
    addressCountry: 'US'
  },
  areaServed: ['Punta Gorda', 'Punta Gorda', 'Southwest Florida'],
  sameAs: ['https://www.facebook.com/fasmotorsports', 'https://www.instagram.com/fasmotorsports']
};
const sanitizedStructuredData = serializeJsonLd(structuredData);
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={sanitizedStructuredData} />
  </Fragment>
  <div {...inlineObjectId('content/pages/about.json')}>
    <!-- Inline-editable Page Title (mapped to content/pages/about.json:title) -->
    <div class="sr-only" {...inlineFieldAttrs('title')}>
      {pageDoc?.title ?? 'About FAS'}
    </div>

    <!-- Hero -->
    <!-- Built by Racing. Carried by Family. -->
    <section class="fas-family-section">
      <div class="fas-family-inner">
        <!-- LEFT: Eyebrow + heading + body -->
        <div class="fas-family-left">
          <div class="fas-family-eyebrow">
            <span class="fas-eyebrow-rule"></span>
            Three Generations. One Standard.
          </div>
          <h2 class="fas-family-heading">
            Built by Racing.<br />Carried by Family.
          </h2>
          <p class="fas-family-body">
            <strong>F.A.S. Motorsports</strong> was built on a foundation most shops can't claim — a professional
            racing legacy started by
            <a href="#legacy" class="fas-inline-link">Frank Mingione II</a>, who set the standard
            before handing it to the next generation.
          </p>
          <p class="fas-family-body">
            When Frank II passed in 2011, Frank III carried the torch. Then Frank IV brought the
            family's obsession with quality into a full-scale manufacturing operation in
            <strong>Punta Gorda, Florida</strong>. The track at Bradenton isn't just nearby — it's
            where our parts get proven before they ever reach a customer.
          </p>
          <p class="fas-family-body">
            Since 2002, we've grown from a performance shop into a
            <a href="/shop/categories/billet-parts" class="fas-inline-link"
              >billet parts manufacturer</a
            >
            with our own CNC equipment, our own fabrication team, and a B2B wholesale network serving
            shops across the country. Every product in our catalog exists because we needed it, couldn't
            find it built right, and decided to build it ourselves.
          </p>
        </div>

        <!-- RIGHT: Dot timeline + callout -->
        <div class="fas-family-right">
          <div class="fas-timeline">
            <div class="fas-tl-item">
              <div class="fas-tl-rail">
                <div class="fas-tl-dot"></div>
                <div class="fas-tl-line"></div>
              </div>
              <div class="fas-tl-content">
                <div class="fas-tl-label">The Foundation</div>
                <div class="fas-tl-name">Frank Mingione II</div>
                <p class="fas-tl-desc">
                  Professional racer. Standard-setter. Built the culture of precision and
                  authenticity that still defines FAS. Passed in 2011. The philosophy he established
                  runs through everything we build.
                </p>
              </div>
            </div>

            <div class="fas-tl-item">
              <div class="fas-tl-rail">
                <div class="fas-tl-dot"></div>
                <div class="fas-tl-line"></div>
              </div>
              <div class="fas-tl-content">
                <div class="fas-tl-label">The Bridge</div>
                <div class="fas-tl-name">Frank Mingione III</div>
                <p class="fas-tl-desc">
                  Carried the legacy after 2011. Kept the standards, expanded the operation, and
                  made sure the family's reputation wasn't just maintained — it was built on.
                </p>
              </div>
            </div>

            <div class="fas-tl-item fas-tl-item--last">
              <div class="fas-tl-rail">
                <div class="fas-tl-dot"></div>
              </div>
              <div class="fas-tl-content">
                <div class="fas-tl-label">Today — Punta Gorda, FL</div>
                <div class="fas-tl-name">Frank Mingione IV</div>
                <p class="fas-tl-desc">
                  Current owner. Scaled a family shop into a full billet manufacturing operation
                  with in-house CNC, custom fab, B2B wholesale distribution, and a dealer network
                  that's still growing.
                </p>
              </div>
            </div>
          </div>

          <!-- Callout -->
          <div class="fas-callout">
            <div class="fas-tl-label">Not Marketing Copy</div>
            <div class="fas-callout-headline">Fast. Aggressive. Superior.</div>
            <p class="fas-callout-body">
              Three words that describe the cars we build, the parts we make, and the standard we
              hold ourselves to. Not a slogan — a commitment that started with Frank II and doesn't
              stop with Frank IV.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- The People Behind the Parts -->
    <section id="legacy" class="about-legacy-section">
      <div class="about-section-inner">
        <div class="about-legacy-header">
          <div class="about-eyebrow">
            <span class="about-eyebrow-rule"></span>
            The People Behind the Parts
          </div>
          <h2 class="about-section-heading">Where It Started</h2>
        </div>

        <div class="about-legacy-grid">
          <!-- Frank II -->
          <div class="about-legacy-card">
            <div class="about-legacy-photo-wrap">
              <Image
                src={img_frank_mingione_i}
                alt="Frank Mingione II"
                class="about-legacy-photo"
              />
              <div class="about-legacy-photo-label">1944 – 2011</div>
            </div>
            <div class="about-legacy-copy">
              <div class="about-eyebrow" style="margin-bottom: 10px;">
                <span class="about-eyebrow-rule"></span>
                The Foundation
              </div>
              <h3 class="about-legacy-name">Frank Mingione II</h3>
              <p class="about-legacy-body">
                Professional racer. The original standard. Frank II built the culture of precision
                and authenticity that still runs through everything FAS makes — long before there
                was a shop. He passed on December 12, 2011. His approach didn't.
              </p>
            </div>
          </div>

          <!-- Frank III -->
          <div class="about-legacy-card about-legacy-card--flip">
            <div class="about-legacy-photo-wrap">
              <Image
                src={img_frank_mingione_ii}
                alt="Frank Mingione III"
                class="about-legacy-photo"
              />
              <div class="about-legacy-photo-label">The Bridge</div>
            </div>
            <div class="about-legacy-copy">
              <div class="about-eyebrow" style="margin-bottom: 10px;">
                <span class="about-eyebrow-rule"></span>
                The Bridge
              </div>
              <h3 class="about-legacy-name">Frank Mingione III</h3>
              <p class="about-legacy-body">
                After 2011, Frank III kept it going. Expanded the operation, formalized the
                knowledge, and made sure every lesson from his father got passed down to his own
                kids — with the same expectations attached.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Shop Floor / Team Photo -->
    <section class="about-team-section">
      <div class="about-team-stats">
        <div class="about-stat">
          <div class="about-stat-number">2002</div>
          <div class="about-stat-label">Founded</div>
        </div>
        <div class="about-stat-divider"></div>
        <div class="about-stat">
          <div class="about-stat-number">3</div>
          <div class="about-stat-label">Generations</div>
        </div>
        <div class="about-stat-divider"></div>
        <div class="about-stat">
          <div class="about-stat-number">1</div>
          <div class="about-stat-label">Shop. Everything in-house.</div>
        </div>
        <div class="about-stat-divider"></div>
        <div class="about-stat">
          <div class="about-stat-number">FL</div>
          <div class="about-stat-label">Punta Gorda</div>
        </div>
      </div>

      <div class="about-team-photo-wrap">
        <Image
          src={img_fas_team_testing_day}
          alt="F.A.S. Motorsports team at Bradenton Motorsports Park"
          class="about-team-photo"
        />
        <div class="about-team-photo-caption">
          Frank Mingione IV + the FAS team — Bradenton Motorsports Park, FL
        </div>
      </div>

      <div class="about-team-footer">
        <p class="about-team-footer-copy">
          Frank Mingione IV runs the shop today. Same building. Same standards. The cars are faster
          than they were in 2002. The expectations are the same.
        </p>
        <div class="about-team-ctas">
          <a href="/shop" class="about-cta-primary">Shop Parts</a>
          <a href="/contact" class="about-cta-secondary">Get in Touch</a>
        </div>
      </div>
    </section>
  </div>

  <style>
    /* ═══════════════════════════════════════════
     Built by Racing. Carried by Family.
  ═══════════════════════════════════════════ */
    .fas-family-section {
      padding: 88px 0 104px;
      background: #0a0a0a;
      border-top: 1px solid rgba(242, 239, 234, 0.06);
    }

    .fas-family-inner {
      width: min(calc(100% - 56px), 1280px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    @media (min-width: 640px) {
      .fas-family-inner {
        width: min(calc(100% - 96px), 1280px);
      }
    }
    @media (min-width: 1024px) {
      .fas-family-inner {
        width: min(calc(100% - 144px), 1280px);
        gap: 96px;
      }
    }
    @media (max-width: 767px) {
      .fas-family-inner {
        grid-template-columns: 1fr;
        gap: 60px;
      }
    }

    /* ── LEFT column ── */
    .fas-family-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #c41218;
      margin-bottom: 22px;
    }

    .fas-eyebrow-rule {
      display: block;
      width: 28px;
      height: 1px;
      background: #c41218;
      flex-shrink: 0;
    }

    .fas-family-heading {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(2.25rem, 5.5vw, 3.75rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: #f2efea;
      margin: 0 0 36px;
    }

    .fas-family-body {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: #8a8682;
      margin: 0 0 20px;
    }

    .fas-family-body:last-of-type {
      margin-bottom: 0;
    }

    .fas-family-body strong {
      color: #d8d4ce;
      font-weight: 600;
    }

    .fas-inline-link {
      color: #c41218;
      text-decoration: none;
      transition: opacity 180ms ease;
    }
    .fas-inline-link:hover {
      opacity: 0.75;
    }

    /* ── RIGHT column ── */
    .fas-family-right {
      display: flex;
      flex-direction: column;
      gap: 40px;
      padding-top: 4px;
    }

    /* ── Timeline ── */
    .fas-timeline {
      display: flex;
      flex-direction: column;
    }

    .fas-tl-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 20px;
    }

    /* Rail = dot + connecting line */
    .fas-tl-rail {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
    }

    .fas-tl-dot {
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: #3a3a3a;
      border: 1.5px solid #555;
      flex-shrink: 0;
      margin-top: 3px;
      transition:
        background 200ms ease,
        border-color 200ms ease,
        box-shadow 200ms ease;
    }

    .fas-tl-line {
      width: 1px;
      flex: 1;
      min-height: 24px;
      background: #2e2e2e;
      margin: 5px 0 0;
      transition: background 200ms ease;
    }

    /* Content per item */
    .fas-tl-content {
      padding-bottom: 32px;
    }
    .fas-tl-item--last .fas-tl-content {
      padding-bottom: 0;
    }

    .fas-tl-label {
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #c41218;
      margin-bottom: 6px;
    }

    .fas-tl-name {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(0.85rem, 1.6vw, 1rem);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #f2efea;
      margin-bottom: 10px;
      line-height: 1.2;
    }

    .fas-tl-desc {
      font-size: 0.875rem;
      line-height: 1.7;
      color: #6e6a66;
      margin: 0;
    }

    /* Hover: dot + line light up red, others dim */
    .fas-tl-item:hover .fas-tl-dot {
      background: #c41218;
      border-color: #c41218;
      box-shadow:
        0 0 0 3px rgba(196, 18, 24, 0.15),
        0 0 12px rgba(196, 18, 24, 0.5);
    }

    .fas-tl-item:hover .fas-tl-line {
      background: rgba(196, 18, 24, 0.6);
    }

    .fas-timeline:has(.fas-tl-item:hover) .fas-tl-item:not(:hover) .fas-tl-dot {
      opacity: 0.35;
    }
    .fas-timeline:has(.fas-tl-item:hover) .fas-tl-item:not(:hover) .fas-tl-content {
      opacity: 0.4;
    }

    /* ── Callout card ── */
    .fas-callout {
      border: 1px solid rgba(196, 18, 24, 0.55);
      border-radius: 10px;
      padding: 24px 26px 26px;
      background: rgba(196, 18, 24, 0.035);
    }

    .fas-callout-headline {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(1rem, 2.2vw, 1.3rem);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #f2efea;
      margin: 8px 0 12px;
      line-height: 1.2;
    }

    .fas-callout-body {
      font-size: 0.875rem;
      line-height: 1.7;
      color: #6e6a66;
      margin: 0;
    }

    /* Reuse .fas-tl-label inside callout */
    .fas-callout .fas-tl-label {
      margin-bottom: 0;
    }

    /* ═══════════════════════════════════════════
     Shared section primitives
  ═══════════════════════════════════════════ */
    .about-section-inner {
      width: min(calc(100% - 56px), 1280px);
      margin: 0 auto;
    }
    @media (min-width: 640px) {
      .about-section-inner {
        width: min(calc(100% - 96px), 1280px);
      }
    }
    @media (min-width: 1024px) {
      .about-section-inner {
        width: min(calc(100% - 144px), 1280px);
      }
    }

    .about-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #c41218;
    }

    .about-eyebrow-rule {
      display: block;
      width: 24px;
      height: 1px;
      background: #c41218;
      flex-shrink: 0;
    }

    .about-section-heading {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(1.5rem, 3.5vw, 2.25rem);
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #f2efea;
      margin: 12px 0 0;
      line-height: 1.1;
    }

    /* ═══════════════════════════════════════════
     Legacy Section
  ═══════════════════════════════════════════ */
    .about-legacy-section {
      padding: 88px 0 96px;
      background: #070707;
      border-top: 1px solid rgba(242, 239, 234, 0.05);
    }

    .about-legacy-header {
      margin-bottom: 56px;
    }

    .about-legacy-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    @media (max-width: 767px) {
      .about-legacy-grid {
        grid-template-columns: 1fr;
        gap: 56px;
      }
    }

    .about-legacy-card {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    /* Flip: on desktop the second card has photo on right */
    @media (min-width: 768px) {
      .about-legacy-card--flip {
        flex-direction: column;
      }
    }

    .about-legacy-photo-wrap {
      position: relative;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: 8px;
      border: 1px solid rgba(242, 239, 234, 0.08);
    }

    .about-legacy-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
      filter: grayscale(20%);
      transition:
        filter 300ms ease,
        transform 400ms ease;
    }

    .about-legacy-card:hover .about-legacy-photo {
      filter: grayscale(0%);
      transform: scale(1.02);
    }

    .about-legacy-photo-label {
      position: absolute;
      bottom: 12px;
      left: 12px;
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(242, 239, 234, 0.6);
      background: rgba(0, 0, 0, 0.65);
      padding: 4px 8px;
      border-radius: 4px;
      backdrop-filter: blur(4px);
    }

    .about-legacy-copy {
      padding: 0 4px;
    }

    .about-legacy-name {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(1rem, 2.2vw, 1.25rem);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #f2efea;
      margin: 0 0 14px;
      line-height: 1.2;
    }

    .about-legacy-body {
      font-size: 0.9rem;
      line-height: 1.78;
      color: #7a7670;
      margin: 0;
    }

    /* ═══════════════════════════════════════════
     Team / Photo Section
  ═══════════════════════════════════════════ */
    .about-team-section {
      background: #0a0a0a;
      border-top: 1px solid rgba(242, 239, 234, 0.05);
      padding-bottom: 96px;
    }

    /* Stats bar */
    .about-team-stats {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      padding: 36px 24px;
      border-bottom: 1px solid rgba(242, 239, 234, 0.06);
      flex-wrap: wrap;
    }

    .about-stat {
      text-align: center;
      padding: 0 36px;
    }

    @media (max-width: 640px) {
      .about-stat {
        padding: 12px 20px;
      }
    }

    .about-stat-number {
      font-family: 'Ethnocentric', sans-serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 700;
      letter-spacing: 0.04em;
      color: #f2efea;
      line-height: 1;
      margin-bottom: 6px;
    }

    .about-stat-label {
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #4a4642;
    }

    .about-stat-divider {
      width: 1px;
      height: 32px;
      background: rgba(242, 239, 234, 0.08);
      flex-shrink: 0;
    }

    @media (max-width: 640px) {
      .about-stat-divider {
        display: none;
      }
    }

    /* Photo */
    .about-team-photo-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 7;
      overflow: hidden;
    }

    @media (max-width: 767px) {
      .about-team-photo-wrap {
        aspect-ratio: 4 / 3;
      }
    }

    .about-team-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
    }

    .about-team-photo-caption {
      position: absolute;
      bottom: 16px;
      right: 20px;
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(242, 239, 234, 0.4);
    }

    /* Footer row */
    .about-team-footer {
      width: min(calc(100% - 56px), 1280px);
      margin: 0 auto;
      padding-top: 52px;
      display: flex;
      align-items: flex-start;
      gap: 64px;
      flex-wrap: wrap;
    }

    @media (min-width: 640px) {
      .about-team-footer {
        width: min(calc(100% - 96px), 1280px);
      }
    }
    @media (min-width: 1024px) {
      .about-team-footer {
        width: min(calc(100% - 144px), 1280px);
        flex-wrap: nowrap;
      }
    }

    .about-team-footer-copy {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: #7a7670;
      margin: 0;
      flex: 1;
      min-width: 260px;
    }

    .about-team-ctas {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-shrink: 0;
      padding-top: 2px;
    }

    .about-cta-primary {
      display: inline-block;
      padding: 11px 24px;
      background: #c41218;
      color: #fff;
      font-family: 'Ethnocentric', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 6px;
      transition: background 180ms ease;
    }
    .about-cta-primary:hover {
      background: #a80f14;
    }

    .about-cta-secondary {
      display: inline-block;
      padding: 11px 24px;
      background: transparent;
