---
/**
 * Order Confirmation Page
 * Displayed after successful payment.
 *
 * Architecture rule: All order data is sourced exclusively from Medusa.
 * No direct Stripe SDK calls are made from this page.
 * The client-side script fetches order details via /api/orders/by-payment-intent,
 * which queries the Medusa admin API as the single source of truth.
 */

// Get payment_intent from query params
const url = new URL(Astro.request.url);
const paymentIntentId = url.searchParams.get('payment_intent');

if (!paymentIntentId) {
  return Astro.redirect('/checkout');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Confirmed - FAS Motorsports</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        background: #000;
        color: #fff;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }

      .confirmation-container {
        max-width: 600px;
        width: 100%;
      }

      .success-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 2rem;
        background: rgba(34, 197, 94, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .success-icon svg {
        width: 48px;
        height: 48px;
        color: #22c55e;
      }

      h1 {
        text-align: center;
        font-size: 2rem;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        text-align: center;
        color: #999;
        margin-bottom: 3rem;
      }

      #order-number-display {
        padding: 1rem;
        border-radius: 8px;
        text-align: center;
        font-size: 1rem;
        min-height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #order-number-display.loaded {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid #22c55e;
        color: #22c55e;
      }

      #order-number-display.error {
        background: rgba(220, 38, 38, 0.1);
        border: 1px solid #dc2626;
        color: #ccc;
      }

      .order-number-label {
        font-weight: 600;
        font-size: 1.25rem;
      }

      .info-box {
        background: #0a0a0a;
        border: 1px solid #1a1a1a;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }

      .info-box h2 {
        font-size: 1.125rem;
        margin-bottom: 1rem;
        color: #fff;
      }

      .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        color: #999;
        border-bottom: 1px solid #1a1a1a;
      }

      .info-row:last-child {
        border-bottom: none;
      }

      .info-row strong {
        color: #fff;
      }

      .total-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem 0;
        border-top: 1px solid #333;
        margin-top: 1rem;
        font-size: 1.25rem;
        font-weight: 600;
      }

      .total-amount {
        color: #dc2626;
      }

      .address-block {
        line-height: 1.6;
        color: #999;
      }

      .next-steps {
        background: rgba(220, 38, 38, 0.1);
        border: 1px solid #dc2626;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
      }

      .next-steps h2 {
        font-size: 1.125rem;
        margin-bottom: 1rem;
        color: #fff;
      }

      .next-steps ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .next-steps li {
        display: flex;
        align-items: start;
        gap: 0.75rem;
        color: #ccc;
      }

      .next-steps li svg {
        flex-shrink: 0;
        margin-top: 2px;
      }

      .button-group {
        display: flex;
        gap: 1rem;
        justify-content: center;
      }

      .button {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
      }

      .button-primary {
        background: #dc2626;
        color: #fff;
      }

      .button-primary:hover {
        background: #b91c1c;
      }

      .button-secondary {
        background: #1a1a1a;
        color: #fff;
        border: 1px solid #333;
      }

      .button-secondary:hover {
        background: #222;
      }

      @media (max-width: 640px) {
        h1 {
          font-size: 1.5rem;
        }

        .button-group {
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <div class="confirmation-container">
      <!-- Success Icon -->
      <div class="success-icon">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"
          ></path>
        </svg>
      </div>

      <!-- Title -->
      <h1>Order Confirmed!</h1>
      <p class="subtitle" id="confirmation-subtitle">
        A confirmation email will be sent to your address on file.
      </p>

      <!-- Order Number Display -->
      <div id="order-number-display" aria-live="polite">
        <!-- Will be populated by client-side script -->
      </div>

      <!-- Order Summary (populated from Medusa via client-side script) -->
      <div class="info-box" id="order-summary-box" style="display:none">
        <h2>Order Summary</h2>
        <div class="info-row">
          <span>Subtotal</span>
          <strong id="order-subtotal">—</strong>
        </div>
        <div class="info-row">
          <span>Shipping</span>
          <strong id="order-shipping">—</strong>
        </div>
        <div class="total-row">
          <span>Total</span>
          <span class="total-amount" id="order-total">—</span>
        </div>
      </div>

      <!-- Shipping Info (populated from Medusa via client-side script) -->
      <div class="info-box" id="shipping-info-box" style="display:none">
        <h2>Shipping Address</h2>
        <div class="address-block" id="shipping-address-block">
          <!-- Populated by script -->
        </div>
      </div>

      <!-- Next Steps -->
      <div class="next-steps">
        <h2>What's Next?</h2>
        <ul>
          <li>
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Your order is being prepared for shipment</span>
          </li>
          <li>
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>You'll receive a tracking number via email once shipped</span>
          </li>
          <li>
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Questions? Contact us at sales@fasmotorsports.com</span>
          </li>
        </ul>
      </div>

      <!-- Action Buttons -->
      <div class="button-group">
        <a href="/" class="button button-primary">Continue Shopping</a>
        <a href="/account/orders" class="button button-secondary">View Orders</a>
      </div>
    </div>

    <!--
      Clear all checkout state (local cart items + Medusa cart ID) after a
      successful order so returning to /checkout starts a completely fresh session.

      Fetch and display order number and order details from Medusa exclusively.
      Architecture rule: All order data comes from Medusa — never from Stripe directly.
    -->
    <script>
      (async () => {
        try {
          // Clear checkout state
          window.localStorage.removeItem('fas_cart_v1');
          window.localStorage.removeItem('fas_medusa_cart_id');
          // Notify any mounted cart islands that the cart is now empty
          window.dispatchEvent(new CustomEvent('cart:changed', { detail: { cart: { items: [] } } }));
        } catch (_) {
          // localStorage may be unavailable in private browsing — silently ignore
        }

        // Fetch order details from Medusa (single source of truth)
        try {
          const params = new URLSearchParams(window.location.search);
          const paymentIntentId = params.get('payment_intent');
          const token = params.get('token');

          if (!paymentIntentId) {
            console.warn('[confirmation] No payment_intent in URL');
            return;
          }

          if (!token) {
            console.warn('[confirmation] No access token in URL');
            const displayDiv = document.getElementById('order-number-display');
            if (displayDiv) {
              displayDiv.classList.add('error');
              displayDiv.innerHTML = 'Order received — check your email for confirmation';
            }
            return;
          }

          const displayDiv = document.getElementById('order-number-display');

          // Attempt to fetch order by payment intent ID with access token (Medusa-sourced)
          const response = await fetch(`/api/orders/by-payment-intent?id=${encodeURIComponent(paymentIntentId)}&token=${encodeURIComponent(token)}`);

          if (response.ok) {
            const data = await response.json();

            // Populate order number
            if (displayDiv) {
              if (data.displayId) {
                displayDiv.classList.add('loaded');
                displayDiv.innerHTML = `<span class="order-number-label">Order #${data.displayId}</span>`;
              } else {
                displayDiv.classList.add('error');
                displayDiv.innerHTML = 'Order received — check your email for confirmation';
              }
            }

            // Populate confirmation subtitle with email if available
            if (data.email) {
              const subtitle = document.getElementById('confirmation-subtitle');
              if (subtitle) {
                subtitle.textContent = `A confirmation email has been sent to ${data.email}`;
              }
            }

            // Populate order summary from Medusa data
            const summaryBox = document.getElementById('order-summary-box');
            if (summaryBox && typeof data.total === 'number') {
              const shipping = typeof data.shippingTotal === 'number' ? data.shippingTotal : 0;
              const subtotal = data.total - shipping;
              const formatCents = (cents) => `$${(cents / 100).toFixed(2)}`;
              document.getElementById('order-subtotal').textContent = formatCents(subtotal);
              document.getElementById('order-shipping').textContent = formatCents(shipping);
              document.getElementById('order-total').textContent = formatCents(data.total);
              summaryBox.style.display = '';
            }

            // Populate shipping address from Medusa data (using safe DOM methods to avoid XSS)
            const shippingBox = document.getElementById('shipping-info-box');
            const addrBlock = document.getElementById('shipping-address-block');
            if (shippingBox && addrBlock && data.shippingAddress) {
              const sa = data.shippingAddress;
              const cityStatePostalLine = [sa.city, sa.state, sa.postalCode].filter(Boolean).join(', ');
              const lines = [sa.name, sa.line1, sa.line2, cityStatePostalLine, sa.country].filter(Boolean);
              addrBlock.textContent = '';
              for (const line of lines) {
                const span = document.createElement('span');
                span.textContent = line;
                addrBlock.appendChild(span);
                addrBlock.appendChild(document.createElement('br'));
              }
              shippingBox.style.display = '';
            }
          } else {
            // 404 or error — order not yet available or not found
            if (displayDiv) {
              displayDiv.classList.add('error');
              displayDiv.innerHTML = 'Order received — check your email for confirmation';
            }
          }
        } catch (err) {
          console.error('[confirmation] Failed to fetch order details:', err);
          const displayDiv = document.getElementById('order-number-display');
          if (displayDiv) {
            displayDiv.classList.add('error');
            displayDiv.innerHTML = 'Order received — check your email for confirmation';
          }
        }
      })();
    </script>
  </body>
</html>
