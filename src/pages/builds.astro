---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={[
    'F.A.S. Motorsports builds',
    'Hellcat performance build',
    'Trackhawk custom build',
    'RAM TRX stage build',
    'Ford F-150 performance package',
    'Mustang GT500 build',
    'custom car builds Punta Gorda',
    'luxury performance shop builds',
    'supercharged builds gallery',
    'performance package showcase'
  ]}
>
  <!-- ══════════════════════════════════════════════════════════════
       HERO SECTION
  ══════════════════════════════════════════════════════════════ -->
  <section class="build-hero" aria-label="Build gallery hero">
    <div class="build-hero__bg" aria-hidden="true">
      <img
        src="/images/backgrounds/hero/fas-garage.webp"
        alt=""
        class="build-hero__bg-img"
        loading="eager"
        decoding="async"
      />
      <div class="build-hero__bg-overlay" aria-hidden="true"></div>
    </div>
    <div class="build-hero__content site-container">
      <p class="build-hero__eyebrow">F.A.S. Motorsports</p>
      <h1 class="build-hero__title">
        <span class="build-hero__title-line1">BUILD</span>
        <span class="build-hero__title-line2">GALLERY</span>
      </h1>
      <p class="build-hero__subtitle">
        Every vehicle that rolls through our Punta Gorda shop leaves transformed.<br
          class="build-hero__br"
        />
        Hellcats, TRXs, Trackhawks, F-Series, Mustangs — built to a standard most shops can&apos;t reach.
      </p>
      <div class="build-hero__stats" aria-label="Shop statistics">
        <div class="build-hero__stat">
          <span class="build-hero__stat-num">6<sup>+</sup></span>
          <span class="build-hero__stat-label">Vehicle Platforms</span>
        </div>
        <div class="build-hero__stat-divider" aria-hidden="true"></div>
        <div class="build-hero__stat">
          <span class="build-hero__stat-num">FL</span>
          <span class="build-hero__stat-label">Punta Gorda, Florida</span>
        </div>
      </div>
    </div>
    <div class="build-hero__scroll-cue" aria-hidden="true">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M12 5v14M5 12l7 7 7-7"></path>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FEATURED BUILDS — editorial spotlight row
  ══════════════════════════════════════════════════════════════ -->
  <section class="build-featured" aria-labelledby="featured-heading">
    <div class="site-container">
      <header class="build-section-header">
        <span class="build-section-header__tag">Spotlight</span>
        <h2 id="featured-heading" class="build-section-header__title">Signature Builds</h2>
        <p class="build-section-header__desc">
          Our most ambitious projects — each one a statement in precision engineering and
          performance.
        </p>
      </header>

      <div class="build-featured__grid">
        {
          featuredBuilds.map((build, i) => {
            const Tag = build.href ? 'a' : 'article';
            return (
              <Tag
                href={build.href ?? undefined}
                class={`build-featured__card${i === 0 ? ' build-featured__card--hero' : ''}${build.href ? ' build-featured__card--link' : ''}`}
                aria-label={build.title}
              >
                <div class="build-featured__card-img-wrap">
                  <img
                    src={build.src}
                    alt={build.alt}
                    class="build-featured__card-img"
                    loading={i < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                  <div class="build-featured__card-overlay" aria-hidden="true" />
                </div>
                <div class="build-featured__card-body">
                  <p class="build-featured__card-sub">{build.subtitle}</p>
                  <h3 class="build-featured__card-title">{build.title}</h3>
                  {build.href && (
                    <span class="build-featured__card-cta">
                      {build.cta ?? 'View Builds'} &rarr;
                    </span>
                  )}
                </div>
              </Tag>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FILTER TABS + MASONRY GALLERY
  ══════════════════════════════════════════════════════════════ -->
  <section class="build-gallery" aria-labelledby="gallery-heading">
    <div class="site-container">
      <header class="build-section-header">
        <span class="build-section-header__tag">Full Portfolio</span>
        <h2 id="gallery-heading" class="build-section-header__title">
          Every Build. Every Platform.
        </h2>
      </header>

      <!-- Filter tabs -->
      <nav class="build-filters" aria-label="Filter builds by category" role="tablist">
        {
          categories.map((cat) => (
            <button
              class="build-filter-btn"
              data-category={cat.id}
              role="tab"
              aria-selected={cat.id === 'all' ? 'true' : 'false'}
              aria-controls="build-gallery-grid"
            >
              {cat.label}
            </button>
          ))
        }
      </nav>

      <!-- Gallery grid -->
      <div id="build-gallery-grid" class="build-grid" role="tabpanel" aria-label="Build gallery">
        {
          builds.map((build) => (
            <article class="build-card" data-category={build.category} aria-label={build.title}>
              <div class="build-card__img-wrap">
                <img
                  src={build.src}
                  alt={build.alt}
                  class="build-card__img"
                  loading="lazy"
                  decoding="async"
                />
                <div class="build-card__shine" aria-hidden="true" />
              </div>
              <div class="build-card__overlay" aria-hidden="true">
                <div class="build-card__overlay-inner">
                  <p class="build-card__overlay-sub">{build.subtitle}</p>
                  <p class="build-card__overlay-title">{build.title}</p>
                </div>
              </div>
              <div class="build-card__footer">
                <p class="build-card__footer-sub">{build.subtitle}</p>
                <p class="build-card__footer-title">{build.title}</p>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Empty state -->
      <div class="build-empty" id="build-empty" aria-live="polite" hidden>
        <p class="build-empty__text">No builds in this category yet.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       CTA STRIP
  ══════════════════════════════════════════════════════════════ -->
  <section class="build-cta" aria-label="Start your build">
    <div class="build-cta__bg" aria-hidden="true">
      <img
        src="/images/backgrounds/bg-asphalt.webp"
        alt=""
        class="build-cta__bg-img"
        loading="lazy"
        decoding="async"
      />
      <div class="build-cta__bg-overlay" aria-hidden="true"></div>
    </div>
    <div class="build-cta__content site-container">
      <h2 class="build-cta__title">Ready to Build?</h2>
      <p class="build-cta__desc">
        Every build in this gallery started with a conversation. Tell us your platform, your goals,
        and we&apos;ll put together a package that delivers.
      </p>
      <div class="build-cta__actions">
        <a href="/schedule" class="build-cta__btn build-cta__btn--primary">
          Schedule a Consultation
        </a>
        <a href="/shop" class="build-cta__btn build-cta__btn--ghost"> Browse Packages </a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- ──────────────────────────────────────────────────────────────
     FILTER SCRIPT
────────────────────────────────────────────────────────────────── -->
<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.build-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.build-card');
  const emptyState = document.getElementById('build-empty');

  function applyFilter(category: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match = category === 'all' || card.dataset.category === category;
      card.hidden = !match;
      if (match) visible++;
    });
    if (emptyState) emptyState.hidden = visible > 0;

    filterBtns.forEach((btn) => {
      const active = btn.dataset.category === category;
      btn.setAttribute('aria-selected', active ? 'true' : 'false');
      btn.classList.toggle('build-filter-btn--active', active);
    });
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.category ?? 'all');
    });
  });

  // Initialize
  applyFilter('all');
</script>

<!-- ──────────────────────────────────────────────────────────────
     STYLES
────────────────────────────────────────────────────────────────── -->
<style>
  /* ── Design tokens ─────────────────────────────────────── */
  :root {
    --red: #ea1d26;
    --red-dark: #c91820;
    --gold: #fde4b2;
    --bg: #121212;
    --bg-card: #1a1a1a;
    --border: rgba(255, 255, 255, 0.08);
    --text-muted: #a1a1aa;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     HERO
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  .build-hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .build-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .build-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: brightness(0.45) saturate(0.8);
  }
  .build-hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(125, 1, 7, 0.15) 50%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  .build-hero__content {
    position: relative;
    z-index: 1;
    padding-block: 6rem 5rem;
  }

  .build-hero__eyebrow {
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.25rem;
  }

  .build-hero__title {
    font-family: 'American Captain', sans-serif;
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 1.5rem;
  }
  .build-hero__title-line1 {
    display: block;
    font-size: clamp(5rem, 14vw, 11rem);
    color: #fff;
  }
  .build-hero__title-line2 {
    display: block;
    font-size: clamp(5rem, 14vw, 11rem);
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.35);
    color: transparent;
  }

  .build-hero__subtitle {
    font-size: clamp(0.875rem, 1.5vw, 1.05rem);
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    max-width: 560px;
    margin-bottom: 3rem;
  }
  .build-hero__br {
    display: none;
  }

  .build-hero__stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 1.5rem;
  }
  .build-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-inline: 2rem;
  }
  .build-hero__stat:first-child {
    padding-left: 0;
  }
  .build-hero__stat-num {
    font-family: 'American Captain', sans-serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--red);
    line-height: 1;
  }
  .build-hero__stat-num sup {
    font-size: 0.55em;
    vertical-align: super;
  }
  .build-hero__stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .build-hero__stat-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.15);
  }

  .build-hero__scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.3);
    animation: scrollBob 2s ease-in-out infinite;
    z-index: 1;
  }
  @keyframes scrollBob {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
