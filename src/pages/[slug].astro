---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SeoLandingPage from '@/components/seo/SeoLandingPage.astro'
import {sanityClient} from '@/lib/sanity/client'
import {seoPageBySlugQuery, seoPageSlugsQuery} from '@/lib/sanity/queries/seoPages'
import {getSeoProducts} from '@/lib/medusa/seoProducts'
import {existsSync, readdirSync} from 'node:fs'
import {join} from 'node:path'
import {fileURLToPath} from 'node:url'

export const prerender = true

type SeoPageSlug = {
  slug: string
}

type SeoPage = {
  title: string
  slug: string
  seoTitle?: string
  seoDescription?: string
  intro?: string
  sections?: Array<{heading: string; body?: unknown[]}>
  ctaHeading?: string
  ctaText?: string
  ctaButtonLabel?: string
  ctaButtonHref?: string
  medusaCollectionHandle: string
  featuredProductHandles?: string[]
}

const STATIC_PAGE_EXTENSIONS = new Set(['.astro', '.md', '.mdx'])
const DYNAMIC_SEGMENT_PATTERN = /^\[.*\]$/

function getReservedTopLevelRouteSlugs(): Set<string> {
  const pagesDir = fileURLToPath(new URL('.', import.meta.url))
  const reserved = new Set<string>()

  for (const entry of readdirSync(pagesDir, {withFileTypes: true})) {
    const name = entry.name
    if (!name || name.startsWith('.')) continue

    if (entry.isDirectory()) {
      if (DYNAMIC_SEGMENT_PATTERN.test(name)) continue

      const hasIndexRoute = ['index.astro', 'index.md', 'index.mdx'].some((indexFile) =>
        existsSync(join(pagesDir, name, indexFile))
      )

      if (hasIndexRoute) {
        reserved.add(name.toLowerCase())
      }
      continue
    }

    if (!entry.isFile()) continue
    if (DYNAMIC_SEGMENT_PATTERN.test(name)) continue

    const extensionIndex = name.lastIndexOf('.')
    if (extensionIndex <= 0) continue

    const baseName = name.slice(0, extensionIndex)
    const extension = name.slice(extensionIndex)

    if (!STATIC_PAGE_EXTENSIONS.has(extension)) continue
    if (!baseName || baseName === 'index' || baseName.includes('.')) continue

    reserved.add(baseName.toLowerCase())
  }

  return reserved
}

export async function getStaticPaths() {
  const pages = await sanityClient.fetch<SeoPageSlug[]>(seoPageSlugsQuery)
  const reservedTopLevelSlugs = getReservedTopLevelRouteSlugs()
  const collidingSlugs = new Set<string>()

  const paths = (pages || [])
    .filter((page) => {
      if (typeof page?.slug !== 'string') return false
      const normalizedSlug = page.slug.trim().toLowerCase()
      if (!normalizedSlug) return false

      if (reservedTopLevelSlugs.has(normalizedSlug)) {
        collidingSlugs.add(normalizedSlug)
        return false
      }

      return true
    })
    .map((page) => ({
      params: {slug: page.slug.trim()},
    }))

  if (collidingSlugs.size > 0) {
    console.warn(
      `[seo-pages] Skipping ${collidingSlugs.size} SEO slug(s) that collide with static top-level routes: ${Array.from(collidingSlugs).join(', ')}`
    )
  }

  return paths
}

const {slug} = Astro.params

if (!slug) {
  throw new Error('Missing slug param')
}

const page = await sanityClient.fetch<SeoPage | null>(seoPageBySlugQuery, {slug})

if (!page) {
  return new Response(null, {status: 404})
}

let products: Awaited<ReturnType<typeof getSeoProducts>> = []

try {
  products = await getSeoProducts({
    featuredProductHandles: page.featuredProductHandles,
    medusaCollectionHandle: page.medusaCollectionHandle,
  })
} catch (error) {
  console.error(`[seo-pages] Failed to fetch products for "${slug}"`, error)
}
---

<BaseLayout title={page.seoTitle || page.title} description={page.seoDescription || page.intro}>
  <SeoLandingPage
    title={page.title}
    intro={page.intro}
    sections={page.sections}
    products={products}
    ctaHeading={page.ctaHeading}
    ctaText={page.ctaText}
    ctaButtonLabel={page.ctaButtonLabel}
    ctaButtonHref={page.ctaButtonHref}
  />
</BaseLayout>
