---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SeoLandingPage from '@/components/seo/SeoLandingPage.astro'
import {sanityClient} from '@/lib/sanity/client'
import {seoPageBySlugQuery} from '@/lib/sanity/queries/seoPages'
import {getSeoProducts} from '@/lib/medusa/seoProducts'

export const prerender = false

type SeoPage = {
  title: string
  slug: string
  seoTitle?: string
  seoDescription?: string
  intro?: string
  sections?: Array<{heading: string; body?: unknown[]}>
  ctaHeading?: string
  ctaText?: string
  ctaButtonLabel?: string
  ctaButtonHref?: string
  medusaCollectionHandle?: string
  vendureCollectionHandle?: string
  featuredProductHandles?: string[]
}

function getQuoteHref(inputHref: string | undefined, pageTitle: string, sourceSlug: string): string {
  const baseHref = typeof inputHref === 'string' && inputHref.trim() ? inputHref.trim() : '/quote'
  if (!baseHref.startsWith('/quote')) return baseHref

  const url = new URL(baseHref, 'https://fasmotorsports.com')
  if (!url.searchParams.get('subject')) {
    url.searchParams.set('subject', pageTitle)
  }
  if (!url.searchParams.get('source')) {
    url.searchParams.set('source', `/${sourceSlug}/`)
  }
  return `${url.pathname}${url.search}${url.hash}`
}

const {slug} = Astro.params

if (!slug) {
  throw new Error('Missing slug param')
}

const page = await sanityClient.fetch<SeoPage | null>(seoPageBySlugQuery, {slug})

if (!page) {
  return new Response(null, {status: 404})
}

let products: Awaited<ReturnType<typeof getSeoProducts>> = []
const collectionHandle = page.medusaCollectionHandle ?? page.vendureCollectionHandle

try {
  if ((page.featuredProductHandles?.length ?? 0) > 0 || collectionHandle) {
    products = await getSeoProducts({
      featuredProductHandles: page.featuredProductHandles,
      medusaCollectionHandle: collectionHandle ?? '',
    })
  }
} catch (error) {
  console.error(`[seo-pages] Failed to fetch products for "${slug}"`, error)
}

const ctaButtonHref = getQuoteHref(page.ctaButtonHref, page.title, slug)
---

<BaseLayout title={page.seoTitle || page.title} description={page.seoDescription || page.intro}>
  <SeoLandingPage
    title={page.title}
    intro={page.intro}
    sections={page.sections}
    products={products}
    ctaHeading={page.ctaHeading}
    ctaText={page.ctaText}
    ctaButtonLabel={page.ctaButtonLabel}
    ctaButtonHref={ctaButtonHref}
  />
</BaseLayout>
