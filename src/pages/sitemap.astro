---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSitemapInventory } from '@/lib/sitemap';

const requestUrl = new URL(Astro.request.url);
requestUrl.search = '';
requestUrl.hash = '';
const canonical = requestUrl.toString();

const pageTitle = 'Sitemap';
const pageDescription = 'Browse all public pages on FAS Motorsports.';

// Single source of truth — same inventory used by XML sitemaps
const sections = await getSitemapInventory();

const totalUrls = sections.reduce((sum, s) => sum + s.entries.length, 0);

const toPath = (loc: string) => {
  try {
    const url = new URL(loc);
    return url.pathname;
  } catch {
    return loc;
  }
};

const renderLastmod = (value?: string) => {
  if (!value) return 'n/a';
  const date = new Date(value);
  if (!Number.isFinite(date.getTime())) return 'n/a';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const XML_SITEMAPS = [
  { href: '/sitemap_index.xml', label: 'Sitemap Index' },
  { href: '/sitemap-core.xml', label: 'Core' },
  { href: '/sitemap-services.xml', label: 'Services' },
  { href: '/sitemap-platforms.xml', label: 'Platforms' },
  { href: '/sitemap-packages.xml', label: 'Packages' },
  { href: '/sitemap-shop-categories.xml', label: 'Shop Categories' },
  { href: '/sitemap-shop-products.xml', label: 'Shop Products' },
  { href: '/sitemap-blog.xml', label: 'Blog' },
  { href: '/sitemap-vendors.xml', label: 'Vendors' },
  { href: '/sitemap-images.xml', label: 'Images' },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} hideBreadcrumbs={false}>
  <section class="sitemap-page">
    <div class="sitemap-shell">
      <p class="sitemap-kicker">Site Directory</p>
      <h1>Sitemap</h1>
      <p class="sitemap-sub">
        {totalUrls.toLocaleString()} public URLs across {sections.length} sections.
        This page updates automatically as new content is added.
      </p>

      <div class="sitemap-xml-links">
        {XML_SITEMAPS.map((link) => (
          <a href={link.href}>{link.label} XML</a>
        ))}
      </div>

      {sections.map((section) => (
        <div class="sitemap-section">
          <h2>
            {section.label}
            <span class="section-count">{section.entries.length.toLocaleString()}</span>
          </h2>
          <ul>
            {section.entries.map((entry) => (
              <li>
                <a href={entry.loc}>{toPath(entry.loc)}</a>
                <span>{renderLastmod(entry.lastmod)}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .sitemap-page {
    padding: 48px 0 88px;
  }

  .sitemap-shell {
    width: min(calc(100% - 40px), 1100px);
    margin: 0 auto;
  }

  .sitemap-kicker {
    margin: 0 0 10px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.64rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #c41218;
  }

  h1 {
    margin: 0;
    font-family: 'Ethnocentric', sans-serif;
    font-size: clamp(1.6rem, 5vw, 2.7rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #f2efea;
  }

  .sitemap-sub {
    margin: 16px 0 22px;
    color: #a7a39d;
    max-width: 720px;
    line-height: 1.6;
  }

  .sitemap-xml-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }

  .sitemap-xml-links a {
    display: inline-block;
    border: 1px solid rgba(242, 239, 234, 0.16);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 0.8rem;
    color: #d3d0cb;
    text-decoration: none;
  }

  .sitemap-xml-links a:hover {
    color: #f2efea;
    border-color: rgba(196, 18, 24, 0.6);
  }

  .sitemap-section {
    margin-top: 28px;
    border: 1px solid rgba(242, 239, 234, 0.1);
    border-radius: 14px;
    overflow: hidden;
    background: rgba(13, 13, 13, 0.55);
  }

  .sitemap-section h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(242, 239, 234, 0.1);
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #f2efea;
  }

  .section-count {
    margin-left: auto;
    font-family: inherit;
    font-size: 0.68rem;
    color: #8c8882;
    letter-spacing: 0.05em;
  }

  .sitemap-section ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sitemap-section li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 10px 16px;
    border-top: 1px solid rgba(242, 239, 234, 0.06);
  }

  .sitemap-section li:first-child {
    border-top: 0;
  }

  .sitemap-section a {
    color: #d3d0cb;
    text-decoration: none;
    word-break: break-word;
  }

  .sitemap-section a:hover {
    color: #ffffff;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .sitemap-section span {
    flex-shrink: 0;
    color: #8c8882;
    font-size: 0.78rem;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .sitemap-section li {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .sitemap-section span {
      white-space: normal;
    }
  }
</style>
