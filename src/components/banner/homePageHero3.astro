---
import { Image } from 'astro:assets';
import heroBg from '@/assets/backgrounds/hero/fas-hero-bg.webp';
import BrandDivider from '../divider/brandDivider';

type Cta = { label: string; href: string };
type Props = {
  bgUrl?: string;
  titleTop?: string;
  titleEmphasis?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
};

const {
  bgUrl,
  titleTop = 'Power Up Your Ride',
  titleEmphasis = 'Unleash Performance',
  subtitle = 'Performance upgrades, billet components, and custom packages for supported platforms.',
  primaryCta = { label: 'Shop Performance', href: '/shop' },
  secondaryCta = { label: 'View Packages', href: '/packages' }
} = Astro.props as Props;

const cleanTitleEmphasis = titleEmphasis.trim();
const lastSpaceIndex = cleanTitleEmphasis.lastIndexOf(' ');
const titleLead =
  lastSpaceIndex > 0 ? cleanTitleEmphasis.slice(0, lastSpaceIndex) : cleanTitleEmphasis;
const titleAccent = lastSpaceIndex > 0 ? cleanTitleEmphasis.slice(lastSpaceIndex + 1) : '';
---

<section class="fas-hero-ultra" aria-label="FAS Hero">
  <div class="fas-hero-bg" aria-hidden="true">
    {
      bgUrl ? (
        <img src={bgUrl} alt="" class="fas-hero-bg-image" loading="eager" decoding="async" />
      ) : (
        <Image
          src={heroBg}
          alt=""
          class="fas-hero-bg-image"
          widths={[640, 960, 1280, 1600, 1920, 2560]}
          sizes="100vw"
          format="webp"
          quality={80}
          loading="eager"
          decoding="async"
        />
      )
    }
  </div>
  <div class="fas-hero-vignette"></div>
  <div class="fas-hero-grid"></div>

  <div class="fas-hero-glow"></div>

  <div class="fas-hero-wrap">
    <div class="fas-hero-left">
      <div class="w-full flex justify-start">
        <BrandDivider className="w-full !justify-start !mb-4 sm:!mb-6 lg:!mb-8" />
      </div>

      <h1 class="fas-hero-h1">
        <span class="top">{titleTop}</span>
        <span class="main">
          <span>{titleLead}</span>
          {titleAccent && <span class="tone-muted"> {titleAccent}</span>}
        </span>
      </h1>

      <p class="fas-hero-p">{subtitle}</p>

      <div class="fas-hero-cta">
        <a class="btn btn-primary" href={primaryCta.href}>
          {primaryCta.label}
        </a>
        <a class="btn btn-ghost" href={secondaryCta.href}>
          {secondaryCta.label}
        </a>
      </div>
    </div>

    <div class="fas-hero-right">
      <div class="fas-hero-card">
        <div class="card-top">
          <span class="badge">AVAILABLE</span>
          <span class="slash"></span>
          <span class="mini">Custom Packages + Parts</span>
        </div>

        <div class="card-mid">
          <div class="line"></div>
          <div class="spec">
            <span>Platforms</span>
            <b>Hellcat • TRX • Trackhawk</b>
          </div>
          <div class="spec">
            <span>Focus</span>
            <b>Boost • Airflow • Cooling</b>
          </div>
          <div class="spec">
            <span>Build Style</span>
            <b>Street • Track • Drag</b>
          </div>
        </div>

        <a class="card-link" href="/builds"> See Build Gallery → </a>
      </div>
    </div>
  </div>
</section>

<style>
  .fas-hero-ultra {
    position: relative;
    isolation: isolate;
    min-height: clamp(620px, 72vh, 900px);
    overflow: hidden;
    border: 0;
    border-radius: 0;
    margin-inline: 0;
    margin-top: 0;
    background: #06070b;
  }

  .fas-hero-bg,
  .fas-hero-vignette,
  .fas-hero-grid,
  .fas-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .fas-hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .fas-hero-vignette {
    background: radial-gradient(
      120% 100% at 12% 75%,
      rgba(0, 0, 0, 0) 0%,
      rgba(5, 7, 12, 0.8) 65%,
      rgba(3, 4, 8, 0.95) 100%
    );
    z-index: 1;
  }

  .fas-hero-grid {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: 0.18;
    z-index: 2;
  }

  .fas-hero-glow {
    background:
      radial-gradient(35rem 22rem at 76% 18%, rgba(225, 26, 33, 0.34), transparent 68%),
      radial-gradient(34rem 20rem at 18% 72%, rgba(227, 35, 35, 0.16), transparent 70%);
    z-index: 3;
  }

  .fas-hero-wrap {
    position: relative;
    z-index: 4;
    height: 100%;
    min-height: inherit;
    padding: clamp(1.25rem, 3.8vw, 3rem);
    display: grid;
    align-items: end;
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }

  .fas-hero-left {
    max-width: 740px;
  }

  .fas-hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.78rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(8, 10, 15, 0.7);
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.66rem, 0.85vw, 0.82rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }

  .fas-hero-chip .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #ea1d28;
    box-shadow: 0 0 0 5px rgba(234, 29, 40, 0.2);
  }

  .fas-hero-h1 {
    margin-top: 0.92rem;
    display: grid;
    gap: 0.15rem;
    line-height: 0.95;
  }

  .fas-hero-h1 .top {
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: clamp(0.84rem, 1.2vw, 1.06rem);
    color: rgba(255, 255, 255, 0.86);
  }

  .fas-hero-h1 .main {
    font-family: 'Ethnocentric', 'JetBrains Mono', monospace;
    font-size: clamp(1.75rem, 4.35vw, 4.3rem);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.03em;
    color: #f7f9ff;
    text-shadow: 0 12px 34px rgba(226, 28, 36, 0.34);
  }

  .fas-hero-h1 .main .tone-muted {
    color: rgba(156, 163, 175, 0.96);
    text-shadow: none;
  }

  .fas-hero-p {
    margin-top: 0.88rem;
    max-width: 64ch;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.9rem, 1.2vw, 1.06rem);
    line-height: 1.55;
    color: rgba(236, 238, 246, 0.9);
  }

  .fas-hero-cta {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .fas-hero-cta .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.72rem 1.15rem;
    text-decoration: none;
    font-family: 'Ethnocentric', 'JetBrains Mono', monospace;
    font-size: clamp(0.68rem, 0.95vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .fas-hero-cta .btn:hover {
    transform: translateY(-1px);
  }

  .fas-hero-cta .btn-primary {
    background: linear-gradient(90deg, #dd171e 0%, #a80f14 100%);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 12px 28px rgba(203, 21, 28, 0.35);
  }

  .fas-hero-cta .btn-ghost {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(8, 11, 16, 0.58);
  }

  .fas-hero-metrics {
    margin-top: 1.18rem;
    display: grid;
    gap: 0.72rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .fas-hero-metrics .metric {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    background: rgba(8, 10, 15, 0.5);
    padding: 0.65rem 0.75rem;
    backdrop-filter: blur(4px);
  }

  .fas-hero-metrics .k {
    font-family: 'Ethnocentric', 'JetBrains Mono', monospace;
    color: #fff;
    font-size: clamp(0.72rem, 0.98vw, 0.9rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fas-hero-metrics .v {
    margin-top: 0.2rem;
    font-family: 'JetBrains Mono', monospace;
    color: rgba(230, 234, 244, 0.84);
    font-size: clamp(0.68rem, 0.9vw, 0.8rem);
  }

  .fas-hero-right {
    justify-self: end;
    width: min(100%, 430px);
    align-self: end;
  }

  .fas-hero-card {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(11, 14, 20, 0.85) 0%, rgba(8, 11, 16, 0.7) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 20px 38px rgba(0, 0, 0, 0.45);
    padding: 0.9rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: rgba(235, 237, 246, 0.95);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .card-top .badge {
    border: 1px solid rgba(225, 35, 41, 0.62);
    border-radius: 999px;
    padding: 0.3rem 0.6rem;
    color: #fff;
    background: rgba(196, 26, 34, 0.22);
  }

  .card-top .slash {
    width: 1px;
    height: 0.95rem;
    background: rgba(255, 255, 255, 0.32);
  }

  .card-mid {
    margin-top: 0.74rem;
    display: grid;
    gap: 0.5rem;
  }

  .card-mid .line {
    height: 2px;
    width: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(226, 28, 36, 0.7) 0%, rgba(226, 28, 36, 0.15) 80%);
  }

  .card-mid .spec {
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 10px;
    padding: 0.58rem 0.62rem;
    background: rgba(11, 14, 22, 0.45);
    display: grid;
    gap: 0.2rem;
  }

  .card-mid .spec span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: rgba(220, 224, 236, 0.74);
  }

  .card-mid .spec b {
    font-family: 'Ethnocentric', 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    color: #fff;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  .card-link {
    margin-top: 0.74rem;
    display: inline-flex;
    color: #fff;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    padding-bottom: 0.13rem;
  }

  @media (max-width: 960px) {
    .fas-hero-ultra {
      min-height: 0;
      border-radius: 0;
    }

    .fas-hero-wrap {
      grid-template-columns: 1fr;
      align-items: end;
      gap: 1rem;
      padding: 1rem;
      min-height: clamp(620px, 78vh, 760px);
    }

    .fas-hero-left {
      max-width: 100%;
    }

    .fas-hero-p {
      max-width: 56ch;
      font-size: clamp(0.82rem, 3.4vw, 0.95rem);
      line-height: 1.45;
    }

    .fas-hero-cta {
      margin-top: 0.95rem;
      gap: 0.55rem;
    }

    .fas-hero-cta .btn {
      padding: 0.62rem 0.95rem;
      font-size: 0.72rem;
      letter-spacing: 0.05em;
    }

    .fas-hero-right {
      justify-self: stretch;
      width: 100%;
    }

    .fas-hero-card {
      padding: 0.75rem;
    }

    .card-top {
      font-size: 0.66rem;
      gap: 0.45rem;
    }

    .card-mid .spec span {
      font-size: 0.62rem;
    }

    .card-mid .spec b {
      font-size: 0.66rem;
    }

    .card-link {
      font-size: 0.68rem;
    }

    .fas-hero-metrics {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .fas-hero-wrap {
      padding: 0.85rem;
      min-height: clamp(560px, 72vh, 680px);
    }

    .fas-hero-h1 {
      gap: 0.08rem;
    }

    .fas-hero-h1 .top {
      font-size: clamp(0.7rem, 2.9vw, 0.84rem);
    }

    .fas-hero-h1 .main {
      font-size: clamp(1.45rem, 8vw, 2.1rem);
    }

    .fas-hero-p {
      font-size: clamp(0.76rem, 3vw, 0.88rem);
      line-height: 1.4;
    }
  }
</style>
