---
import FasTopBar from './fas-topBar.astro';
import MobileMenu from '@/components/navbar/mobile-menu.tsx';
import CartEntry from '@/components/cart/CartEntry.tsx';
import CartButton from '@/components/cart/cart-button.tsx';
import { SearchBar } from '@/components/SearchBar.tsx';

type MenuLink = { label: string; href: string };

const sortByLabel = (a: MenuLink, b: MenuLink) => a.label.localeCompare(b.label);

const shopLinks = [
  { label: 'All Products', href: '/shop' },
  { label: 'Performance Packages', href: '/shop/performance-packages' },
  { label: 'Wheels & Tires', href: '/wheels' },
  { label: 'Categories', href: '/shop/categories' }
].sort(sortByLabel);

const billetLinks = [
  { label: 'Shop Billet Parts', href: '/shop/categories/billet-parts' },
  { label: 'Predator Pulley', href: '/specs/PredatorPulley' },
  { label: 'Pulley Hub', href: '/specs/PulleyHub' },
  { label: 'Billet Bearing Plate', href: '/specs/BilletBearingPlate' },
  { label: 'Billet Snout', href: '/specs/BilletSnout' }
];

const packageLinks = [
  { label: 'All Packages', href: '/packages' },
  { label: 'Power Packages', href: '/packages/powerPackages' },
  { label: 'Truck Packages', href: '/packages/truckPackages' }
].sort(sortByLabel);

const serviceLinks = [
  { label: 'Core Exchange', href: '/services/coreExchange' },
  { label: 'Custom Fabrication', href: '/services/customFab' },
  { label: 'IGLA Security', href: '/services/igla' },
  { label: 'Overview', href: '/services/overview' },
  { label: 'Porting', href: '/services/porting' },
  { label: 'Welding', href: '/services/welding' }
].sort(sortByLabel);
---

<FasTopBar />
<CartEntry client:only="react" />
<div class="fas-nav-sticky">
  <div class="fas-header-mobile-shell">
    <header class="fas-mobile-header" aria-label="Mobile site header">
      <div class="fas-mobile-header-inner">
        <a href="/" class="homepage-logo" aria-label="F.A.S. Motorsports home">
          <span class="homepage-logo-mark">F.A.S.</span>
          <span class="homepage-logo-sub">Motorsports</span>
        </a>

        <div class="fas-mobile-actions">
          <a
            href="/search"
            class="fas-search-trigger fas-search-mobile-trigger"
            aria-label="Search the website"
            title="Search"
          >
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.9"></circle>
              <path
                d="M16.1 16.1 21 21"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
              ></path>
            </svg>
          </a>

          <CartButton client:only="react" />

          <div class="fas-mobile-menu" aria-label="Mobile navigation">
            <MobileMenu client:only="react" />
          </div>
        </div>
      </div>
    </header>
  </div>

  <header class="fas-desktop-header" aria-label="Desktop site header">
    <div class="fas-desktop-header-inner">
      <a href="/" class="homepage-logo" aria-label="F.A.S. Motorsports home">
        <span class="homepage-logo-mark">F.A.S.</span>
        <span class="homepage-logo-sub">Motorsports</span>
      </a>

      <ul class="nav-links" role="menubar">
        <li class="nav-item" role="none">
          <a href="/shop" class="nav-link" role="menuitem" aria-haspopup="true">
            Shop
            <svg viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path
                d="M1 1l4 4 4-4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <div class="nav-dropdown" role="menu">
            {
              shopLinks.map((item) => (
                <a href={item.href} role="menuitem">
                  {item.label}
                </a>
              ))
            }
          </div>
        </li>
        <li class="nav-item" role="none">
          <a
            href="/shop/categories/billet-parts"
            class="nav-link"
            role="menuitem"
            aria-haspopup="true"
          >
            Billet Parts
            <svg viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path
                d="M1 1l4 4 4-4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <div class="nav-dropdown" role="menu">
            {
              billetLinks.map((item) => (
                <a href={item.href} role="menuitem">
                  {item.label}
                </a>
              ))
            }
          </div>
        </li>
        <li class="nav-item" role="none">
          <a href="/packages" class="nav-link" role="menuitem" aria-haspopup="true">
            Packages
            <svg viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path
                d="M1 1l4 4 4-4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <div class="nav-dropdown" role="menu">
            {
              packageLinks.map((item) => (
                <a href={item.href} role="menuitem">
                  {item.label}
                </a>
              ))
            }
          </div>
        </li>
        <li class="nav-item" role="none">
          <a href="/services" class="nav-link" role="menuitem" aria-haspopup="true">
            Services
            <svg viewBox="0 0 10 6" fill="none" aria-hidden="true">
              <path
                d="M1 1l4 4 4-4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <div class="nav-dropdown" role="menu">
            {
              serviceLinks.map((item) => (
                <a href={item.href} role="menuitem">
                  {item.label}
                </a>
              ))
            }
          </div>
        </li>
        <li class="nav-item" role="none">
          <a href="/about" class="nav-link" role="menuitem">About</a>
        </li>
        <li class="nav-item" role="none">
          <a href="/contact" class="nav-link" role="menuitem">Contact</a>
        </li>
      </ul>

      <div class="desktop-actions">
        <a href="/account" class="desktop-login-btn">Login</a>
        <div class="desktop-search-wrap fas-search-desktop" data-search-wrap>
          <button
            type="button"
            class="fas-search-trigger fas-search-toggle"
            aria-label="Open search"
            aria-expanded="false"
            aria-controls="desktopSearchPanel"
            data-search-toggle
          >
            <svg class="search-icon-open" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.9"></circle>
              <path
                d="M16.1 16.1 21 21"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
              ></path>
            </svg>
            <svg class="search-icon-close" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M6 6 18 18M18 6 6 18"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
              ></path>
            </svg>
          </button>
          <div
            id="desktopSearchPanel"
            class="desktop-search-shell"
            aria-label="Website search"
            data-search-panel
          >
            <SearchBar
              client:load
              action="/search"
              enableSuggestions={true}
              size="compact"
              variant="storefront"
              placeholder="Search products, services, pages..."
            />
          </div>
        </div>
        <CartButton client:only="react" />
      </div>
    </div>
  </header>
</div>
<button
  type="button"
  class="desktop-search-scrim"
  aria-label="Close search"
  aria-hidden="true"
  tabindex="-1"
  data-search-scrim
></button>

<style>
  .fas-nav-sticky {
    position: sticky;
    top: 0;
    z-index: 9999;
    --fas-mobile-header-height: 58px;
    /* Single sticky root — both mobile shell and desktop header live here.
       Topbar (FasTopBar) is a sibling above this wrapper and scrolls away normally. */
  }

  .fas-header-mobile-shell {
    display: block;
    overflow: visible;
  }

  .fas-mobile-header {
    left: 0;
    right: 0;
    width: 100%;
    border-bottom: 1px solid rgba(242, 239, 234, 0.08);
    position: relative;
  }

  .fas-mobile-header::before {
    content: '';
    position: absolute;
    inset: 0;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 8, 8, 0.94);
    z-index: -1;
    pointer-events: none;
  }

  .fas-mobile-header-inner {
    width: min(1280px, calc(100% - 24px));
    margin: 0 auto;
    min-height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .homepage-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    text-decoration: none;
    white-space: nowrap;
  }

  .homepage-logo-mark {
    color: var(--red);
    font-family: 'Borgsquad Italic', sans-serif;
    font-size: clamp(0.9rem, 3.2vw, 1.25rem);
    letter-spacing: clamp(0.04em, 0.24vw, 0.08em);
  }

  .homepage-logo-sub {
    color: #f2efea;
    font-family: 'Ethnocentric', sans-serif;
    font-size: clamp(0.52rem, 1.85vw, 0.76rem);
    letter-spacing: clamp(0.05em, 0.3vw, 0.11em);
    text-transform: uppercase;
  }

  .fas-mobile-actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .fas-search-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 38px;
    width: 38px;
    color: #f2efea;
    border: 1px solid rgba(242, 239, 234, 0.16);
    border-radius: 12px;
    text-decoration: none;
    background: transparent;
    cursor: pointer;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .fas-search-trigger:hover,
  .fas-search-trigger:focus-visible {
    color: #ffffff;
    border-color: rgba(242, 239, 234, 0.34);
    background: rgba(255, 255, 255, 0.05);
    outline: none;
  }

  .fas-search-trigger svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .desktop-search-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0;
    z-index: 10002;
  }

  .fas-search-mobile-trigger {
    display: inline-flex;
  }

  .search-icon-close {
    display: none;
  }

  .fas-mobile-actions :global(button[aria-label='Open cart']),
  .desktop-actions :global(button[aria-label='Open cart']) {
    border: 0;
    background: transparent;
    padding: 0;
    margin: 0;
    cursor: pointer;
    color: inherit;
  }

  .fas-cart-btn {
    text-decoration: none;
    border: none;
    cursor: pointer;
    border-radius: 12px;
    padding: 8px 10px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red);
    color: #fff;
  }

  .fas-cart-btn svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }

  .fas-mobile-menu {
    display: inline-flex;
    align-items: center;
  }

  .fas-mobile-menu :global(button[aria-controls='mobile-nav']) {
    height: 48px;
    width: 48px;
    border-radius: 16px;
    border: none;
    background: transparent;
    color: #f2efea;
    box-shadow: none;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    position: relative;
    z-index: 220;
  }

  .fas-mobile-menu :global(.homepage-hamburger),
  .fas-mobile-menu :global(#hamburger) {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    padding: 0;
  }

  .fas-mobile-menu :global(.homepage-hamburger span),
  .fas-mobile-menu :global(#hamburger span) {
    display: block;
    width: 20px;
    height: 2px;
    background: #f2efea;
    border-radius: 999px;
    transition:
      transform 260ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 260ms cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center;
  }

  .fas-mobile-menu :global(.homepage-hamburger.is-open span:nth-child(1)),
  .fas-mobile-menu :global(#hamburger.is-open span:nth-child(1)) {
    transform: translateY(7px) rotate(45deg);
  }

  .fas-mobile-menu :global(.homepage-hamburger.is-open span:nth-child(2)),
  .fas-mobile-menu :global(#hamburger.is-open span:nth-child(2)) {
    opacity: 0;
  }

  .fas-mobile-menu :global(.homepage-hamburger.is-open span:nth-child(3)),
  .fas-mobile-menu :global(#hamburger.is-open span:nth-child(3)) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .fas-mobile-menu :global(button[aria-controls='mobile-nav']:hover) {
    color: #ffffff;
  }

  .fas-mobile-menu :global(button[aria-controls='mobile-nav']:focus-visible) {
    outline: 2px solid rgba(242, 239, 234, 0.45);
    outline-offset: 2px;
  }

  .fas-mobile-menu :global(#mobile-nav),
  .fas-mobile-menu :global(.mobile-nav) {
    position: absolute;
    top: 100%;
    right: 0;
    left: 0;
    z-index: 180;
    background: #080808;
    transform: translateX(100%);
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    height: calc(100dvh - var(--fas-mobile-header-height));
    max-height: calc(100dvh - var(--fas-mobile-header-height));
    overflow: hidden;
    will-change: transform;
  }

  .fas-mobile-menu :global(#mobile-nav.open),
  .fas-mobile-menu :global(.mobile-nav.open) {
    transform: translateX(0);
  }

  /* Internal drawer header: logo + cart + close */
  .fas-mobile-menu :global(#mobile-nav .mobile-nav-header),
  .fas-mobile-menu :global(.mobile-nav-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 20px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(242, 239, 234, 0.08);
    background: rgba(8, 8, 8, 0.98);
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-logo img),
  .fas-mobile-menu :global(.mobile-nav-logo img) {
    height: 36px;
    width: auto;
    display: block;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-header-actions),
  .fas-mobile-menu :global(.mobile-nav-header-actions) {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-cart-pill),
  .fas-mobile-menu :global(.mobile-nav-cart-pill) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 10px;
    background: var(--red);
    color: #fff;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-close-btn),
  .fas-mobile-menu :global(.mobile-nav-close-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 0;
    border: none;
    background: transparent;
    color: #f2efea;
    cursor: pointer;
    transition: color 160ms ease;
    padding: 0;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-close-btn:hover),
  .fas-mobile-menu :global(.mobile-nav-close-btn:hover) {
    background: transparent;
    color: #ffffff;
  }

  /* Scrollable content area below the internal header */
  .fas-mobile-menu :global(#mobile-nav .mobile-nav-inner),
  .fas-mobile-menu :global(.mobile-nav-inner) {
    flex: 1;
    overflow-y: auto;
    padding: 8px 20px 40px;
    -webkit-overflow-scrolling: touch;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-inner ul),
  .fas-mobile-menu :global(.mobile-nav-inner ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-inner li),
  .fas-mobile-menu :global(.mobile-nav-inner li) {
    margin: 0;
    padding: 0;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-link),
  .fas-mobile-menu :global(.mobile-nav-link) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 4px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #d3d0cb;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-link:hover),
  .fas-mobile-menu :global(.mobile-nav-link:hover) {
    color: #f2efea;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-sub),
  .fas-mobile-menu :global(.mobile-nav-sub) {
    padding: 8px 0 8px 12px;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-sub a),
  .fas-mobile-menu :global(.mobile-nav-sub a) {
    display: block;
    padding: 8px 4px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9f9b96;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-sub a:hover),
  .fas-mobile-menu :global(.mobile-nav-sub a:hover) {
    color: #d3d0cb;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-ctas),
  .fas-mobile-menu :global(.mobile-nav-ctas) {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 24px;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-nav-ctas a),
  .fas-mobile-menu :global(.mobile-nav-ctas a) {
    display: block;
    padding: 14px;
    text-align: center;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 8px;
    text-decoration: none;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-cta-primary),
  .fas-mobile-menu :global(.mobile-cta-primary) {
    background: var(--red);
    color: #fff;
  }

  .fas-mobile-menu :global(#mobile-nav .mobile-cta-outline),
  .fas-mobile-menu :global(.mobile-cta-outline) {
    border: 1px solid rgba(196, 18, 24, 0.6);
    color: var(--red);
  }

  .fas-desktop-header {
    display: none;
    left: 0;
    right: 0;
    width: 100%;
    overflow: visible;
    border-bottom: 1px solid rgba(242, 239, 234, 0.08);
  }

  .fas-desktop-header::before {
    content: '';
    position: absolute;
    inset: 0;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 8, 8, 0.94);
    z-index: -1;
    pointer-events: none;
  }

  .fas-desktop-header-inner {
    width: min(1280px, calc(100% - 40px));
    margin: 0 auto;
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    text-decoration: none;
    color: #aba7a2;
    border-radius: 8px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .nav-link:hover {
    color: #f2efea;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link svg {
    width: 10px;
    height: 6px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(242, 239, 234, 0.14);
    background: rgba(13, 13, 13, 0.98);
    box-shadow: 0 20px 42px rgba(0, 0, 0, 0.55);
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
    z-index: 10000;
  }

  .nav-dropdown a {
    display: block;
    color: #aba7a2;
    text-decoration: none;
    font-size: 0.82rem;
    padding: 8px 10px;
    border-radius: 8px;
  }

  .nav-dropdown a:hover {
    color: #f2efea;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-item:hover .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .desktop-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .desktop-search-shell {
    position: absolute;
    right: calc(100% + 10px);
    top: 50%;
    width: min(320px, 28vw);
    min-width: 210px;
    opacity: 0;
    transform: translate3d(16px, -50%, 0) scaleX(0.9);
    transform-origin: right center;
    pointer-events: none;
    max-width: 0;
    overflow: hidden;
    transition:
      max-width 260ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 180ms ease,
      transform 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .desktop-search-shell :global(input[name='q']) {
    height: 38px;
    padding-right: 2.35rem;
    border-radius: 12px;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
  }

  .desktop-search-scrim {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    border: 0;
    padding: 0;
    margin: 0;
    transition: opacity 220ms ease;
    z-index: 9800;
  }

  .fas-nav-sticky.is-search-open .desktop-search-shell {
    max-width: min(420px, 38vw);
    opacity: 1;
    transform: translate3d(0, -50%, 0) scaleX(1);
    pointer-events: auto;
  }

  .fas-nav-sticky.is-search-open .search-icon-open {
    display: none;
  }

  .fas-nav-sticky.is-search-open .search-icon-close {
    display: block;
  }

  .fas-nav-sticky.is-search-open + .desktop-search-scrim {
    opacity: 1;
    pointer-events: auto;
  }

  .fas-nav-sticky.is-search-open .nav-links,
  .fas-nav-sticky.is-search-open .homepage-logo,
  .fas-nav-sticky.is-search-open .desktop-login-btn {
    opacity: 0.45;
    transition: opacity 200ms ease;
  }

  .desktop-login-btn,
  .desktop-cart-btn {
    text-decoration: none;
    border-radius: 10px;
    padding: 10px 14px;
    font-family: 'Ethnocentric', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .desktop-login-btn {
    border: 1px solid rgba(196, 18, 24, 0.45);
    color: #f2efea;
    background: transparent;
  }

  .desktop-login-btn:hover {
    border-color: var(--red);
  }

  .desktop-cart-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red);
    color: #fff;
    border: none;
    cursor: pointer;
  }

  .desktop-cart-btn svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .fas-nav-sticky {
      --fas-mobile-header-height: 56px;
    }

    .fas-mobile-header-inner {
      width: min(100%, calc(100% - 16px));
      min-height: 56px;
    }

    .fas-mobile-actions {
      gap: 6px;
    }

    .fas-search-trigger {
      height: 36px;
      width: 36px;
      border-radius: 10px;
    }

    .fas-cart-btn {
      border-radius: 10px;
      padding: 8px;
      font-size: 0;
    }

    .fas-cart-btn span {
      display: none;
    }

    .fas-mobile-menu :global(button[aria-controls='mobile-nav']) {
      height: 44px;
      width: 44px;
      border-radius: 14px;
    }
  }

  @media (min-width: 1024px) {
    .fas-header-mobile-shell {
      display: none;
    }

    .fas-desktop-header {
      display: block;
    }

    .homepage-logo-mark {
      font-size: clamp(1rem, 1.35vw, 1.36rem);
      letter-spacing: clamp(0.04em, 0.12vw, 0.08em);
    }

    .homepage-logo-sub {
      font-size: clamp(0.56rem, 0.85vw, 0.8rem);
      letter-spacing: clamp(0.07em, 0.2vw, 0.12em);
    }

    .fas-search-mobile-trigger {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .desktop-search-wrap,
    .desktop-search-scrim {
      display: none !important;
    }
  }

</style>

<script is:inline>
  (() => {
    const root = document.querySelector('.fas-nav-sticky');
    const toggle = root?.querySelector('[data-search-toggle]');
    const panel = root?.querySelector('[data-search-panel]');
    const scrim = document.querySelector('[data-search-scrim]');
    if (!root || !toggle || !panel || !scrim) return;
    const desktopMq = window.matchMedia('(min-width: 1024px)');

    const focusInput = () => {
      const tryFocus = (attempt = 0) => {
        const input = panel.querySelector('input[name="q"]');
        if (input instanceof HTMLInputElement) {
          input.focus();
          return;
        }
        if (attempt < 8) {
          window.setTimeout(() => tryFocus(attempt + 1), 45);
        }
      };
      tryFocus();
    };

    const openSearch = () => {
      if (!desktopMq.matches) return;
      root.classList.add('is-search-open');
      toggle.setAttribute('aria-expanded', 'true');
      focusInput();
    };

    const closeSearch = () => {
      root.classList.remove('is-search-open');
      toggle.setAttribute('aria-expanded', 'false');
    };

    toggle.addEventListener('click', () => {
      if (root.classList.contains('is-search-open')) {
        closeSearch();
      } else {
        openSearch();
      }
    });

    scrim.addEventListener('click', closeSearch);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeSearch();
    });
    desktopMq.addEventListener('change', (event) => {
      if (!event.matches) closeSearch();
    });
  })();
</script>
