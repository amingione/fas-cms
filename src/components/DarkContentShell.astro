---
interface Props {
  maxWidthClass?: string;
  sectionClass?: string;
  contentClass?: string;
}

const {
  maxWidthClass = 'max-w-5xl',
  sectionClass = '',
  contentClass = ''
} = Astro.props;

const sectionClasses = ['bg-dark py-16 text-white lg:py-20', sectionClass].filter(Boolean).join(' ');
const contentClasses = [
  'rounded-3xl border border-white/10 bg-white/5 px-6 py-10 shadow-[0_24px_80px_rgba(0,0,0,0.45)] backdrop-blur-sm sm:px-8 lg:px-10',
  contentClass
]
  .filter(Boolean)
  .join(' ');
---

<section class={sectionClasses}>
  <div class:list={['mx-auto px-4', maxWidthClass]}>
    <div class={contentClasses}>
      <slot name="title" />
      <slot />
    </div>
  </div>
</section>
