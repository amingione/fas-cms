---

<section class="pp" aria-labelledby="pp-heading">
  <div class="pp-shell">

    <!-- Header -->
    <div class="pp-header">
      <div class="pp-header-left">
        <div class="pp-kicker">
          <span class="pp-kicker-line" aria-hidden="true"></span>
          <span>Install-Only · FAS Parts · Dyno-Proven</span>
        </div>
        <h2 id="pp-heading" class="pp-title">Power Packages</h2>
        <p class="pp-sub">
          Every package is built with parts we designed and manufactured.
          Every install happens in our shop. Every number gets proven on the
          dyno before your keys come back.
        </p>
      </div>
      <a href="/shop/performance-packages" class="pp-all-link">
        All Packages →
      </a>
    </div>

    <!-- Grid -->
    <div class="pp-grid">
      {packages.map((pkg) => (
        <div class:list={['pp-card', pkg.featured && 'pp-card--featured']}>

          <!-- Visual / image area -->
          <div class="pp-visual">
            <img
              src={pkg.image}
              alt={pkg.stage + ' — ' + pkg.platform}
              loading="lazy"
              decoding="async"
            />
            <div class="pp-hp">
              <span class="pp-hp-val">{pkg.hp}</span>
              <span class="pp-hp-unit">HP</span>
            </div>
            <span class="pp-img-label">{pkg.imageLabel}</span>
          </div>

          <!-- Body -->
          <div class="pp-body">
            <span class="pp-platform">{pkg.platform}</span>
            <h3 class="pp-name">{pkg.stage}</h3>

            <ul class="pp-features" aria-label="What's included">
              {pkg.features.map((f) => (
                <li class="pp-feature-item">{f}</li>
              ))}
            </ul>

            <div class="pp-footer">
              <div class="pp-price-wrap">
                <span class="pp-from">Starting From</span>
                <span class="pp-price">{pkg.price}</span>
              </div>
              <a
                href={pkg.href}
                class:list={['pp-btn', pkg.featured && 'pp-btn--featured']}
              >
                Details
              </a>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Shell ── */
  .pp {
    background: var(--bg-base, #09090b);
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .pp-shell {
    width: min(calc(100% - (2 * var(--container-pad-mobile, 20px))), var(--max-w, 1280px));
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .pp-shell {
      width: min(calc(100% - (2 * var(--container-pad-tablet, 32px))), var(--max-w, 1280px));
    }
  }

  @media (min-width: 1024px) {
    .pp-shell {
      width: min(calc(100% - (2 * var(--container-pad-desktop, 72px))), var(--max-w, 1280px));
    }
  }

  /* ── Header ── */
  .pp-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .pp-header-left {
    max-width: 560px;
  }

  .pp-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red, #ea1d26);
    margin-bottom: 0.75rem;
  }

  .pp-kicker-line {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--red, #ea1d26);
    flex-shrink: 0;
  }

  .pp-title {
    font-family: var(--font-display, 'Ethnocentric', sans-serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  .pp-sub {
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: clamp(0.82rem, 1.1vw, 0.95rem);
    color: rgba(220, 224, 236, 0.7);
    line-height: 1.65;
    margin: 0;
    max-width: 50ch;
  }

  .pp-all-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    padding: 0.65rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 3px;
    text-decoration: none;
    white-space: nowrap;
    align-self: flex-start;
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  .pp-all-link:hover {
    border-color: rgba(255, 255, 255, 0.65);
    color: #fff;
  }

  /* ── Grid ── */
  .pp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .pp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pp-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Card ── */
  .pp-card {
    background: var(--bg-surface, #171717);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }

  .pp-card--featured {
    border-color: rgba(234, 29, 38, 0.45);
    box-shadow: inset 0 0 0 1px rgba(234, 29, 38, 0.12),
                0 0 40px rgba(234, 29, 38, 0.06);
  }

  .pp-card--featured:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(234, 29, 38, 0.3);
  }

  /* ── Visual (image + HP overlay) ── */
  .pp-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #0d0d0f;
    overflow: hidden;
  }

  .pp-visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.55) saturate(0.8);
    transition: filter 0.4s ease, transform 0.5s ease;
  }

  .pp-card:hover .pp-visual img {
    filter: brightness(0.65) saturate(0.9);
    transform: scale(1.03);
  }

  /* Red vignette tint from bottom */
  .pp-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(6, 4, 4, 0.75) 100%
    );
    pointer-events: none;
  }

  /* HP number — top-left overlay */
  .pp-hp {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
    line-height: 1;
  }

  .pp-hp-val {
    display: block;
    font-family: var(--font-display, 'Ethnocentric', sans-serif);
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pp-hp-unit {
    display: block;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red, #ea1d26);
    margin-top: 2px;
  }

  /* Image caption — bottom-left */
  .pp-img-label {
    position: absolute;
    bottom: 12px;
    left: 14px;
    z-index: 2;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.52rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  /* ── Body ── */
  .pp-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 18px 20px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .pp-platform {
    display: block;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--red, #ea1d26);
    margin-bottom: 5px;
  }

  .pp-name {
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.2;
    margin: 0 0 14px;
  }

  /* ── Feature list ── */
  .pp-features {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .pp-feature-item {
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.78rem;
    color: rgba(220, 224, 236, 0.75);
    line-height: 1.4;
    padding-left: 14px;
    position: relative;
  }

  .pp-feature-item::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--red, #ea1d26);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  /* ── Footer: price + CTA ── */
  .pp-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .pp-price-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pp-from {
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(161, 161, 170, 0.65);
  }

  .pp-price {
    font-family: var(--font-ui, 'Barlow', sans-serif);
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .pp-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.6rem 1.1rem;
    border-radius: 3px;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    background: transparent;
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s, background 0.2s;
  }

  .pp-btn:hover {
    border-color: rgba(255, 255, 255, 0.65);
  }

  .pp-btn--featured {
    background: var(--red, #ea1d26);
    border-color: var(--red, #ea1d26);
    color: #fff;
  }

  .pp-btn--featured:hover {
    background: #c91820;
    border-color: #c91820;
  }
</style>

<script>
  // Stagger entrance on scroll
  const cards = document.querySelectorAll<HTMLElement>('.pp-card');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.animationPlayState = 'running';
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    cards.forEach((c) => io.observe(c));
  }
</script>
