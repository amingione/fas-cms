---
import { Image } from 'astro:assets';
import fas800HellcatImage from '@/assets/images/packages/Hellcat/FAS-1.webp';
import fas1000HellcatImage from '@/assets/images/packages/Hellcat/FAS-fas-1000-challenger.webp';
import fas1xHellcatImage from '@/assets/images/packages/fas-1x-2.webp';

const packages = [
  // ── Hellcat / Mopar ──────────────────────────────────────────────────────
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS800',
    hp: '800',
    price: 'From $6,499',
    href: '/packages/fas800',
    image: '/images/packages/Hellcat/FAS-1.webp',
    optimizedImage: fas800HellcatImage,
    imageLabel: 'FAS800 — Challenger SRT Hellcat',
    featured: false,
    features: [
      'FAS Upper Pulley Kit',
      'Upgraded Spark Plugs + 180° Thermostat',
      'FAS Custom Engine & Trans Tune',
      'Full In-Shop Install',
    ],
  },
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS1000',
    hp: '1000',
    price: 'From $16,999',
    href: '/packages/fas1000',
    image: '/images/packages/Hellcat/FAS-fas-1000-challenger.webp',
    optimizedImage: fas1000HellcatImage,
    imageLabel: 'FAS1000 — Challenger SRT Hellcat',
    featured: true,
    features: [
      'Race-Ported Supercharger',
      '108mm Throttle Body + High-Flow Intake',
      'Longtube Headers + Race Midpipes',
      'E85 Fuel System + ID Injectors',
      'Custom Dyno Tune — Full Install',
    ],
  },
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS 1X',
    hp: '1500',
    price: 'Call for Pricing',
    href: '/packages/fas-1x',
    image: '/images/packages/fas-1x-2.webp',
    optimizedImage: fas1xHellcatImage,
    imageLabel: 'FAS 1X — Challenger SRT Hellcat',
    featured: false,
    features: [
      '1200–1500 HP Custom Program',
      'Short-Block + Valvetrain Upgrades',
      '3.0 Upper / 9.1 Lower Pulley Combo',
      'Fore Triple-Pump Fuel System',
      'Consultation-Driven Build',
    ],
  },
  // ── RAM TRX ──────────────────────────────────────────────────────────────
  {
    platform: 'RAM TRX',
    stage: 'FAS800',
    hp: '800',
    price: 'From $6,699',
    href: '/packages/fas800',
    image: '/images/packages/FAS-TRX.webp',
    imageLabel: 'FAS800 — RAM 1500 TRX',
    featured: false,
    features: [
      'FAS Upper Pulley Kit + Billet Idler',
      'Upgraded Spark Plugs + 180° Thermostat',
      'FAS Custom Engine & Trans Tune',
      'Full In-Shop Install',
    ],
  },
  {
    platform: 'RAM TRX',
    stage: 'FAS1000',
    hp: '1000',
    price: 'From $17,999',
    href: '/packages/fas1000',
    image: '/images/packages/FAS-ram-trx-build.webp',
    imageLabel: 'FAS1000 — RAM 1500 TRX',
    featured: false,
    features: [
      'Full Race-Ported Supercharger',
      'Long-Tube Headers + Race Midpipes',
      'Fore Dual-Pump Return Fuel System',
      'Dedicated E85 / VP Tune',
      'Full In-Shop Install',
    ],
  },
  // ── Ford F-150 ───────────────────────────────────────────────────────────
  {
    platform: 'Ford F-150 (2018+)',
    stage: 'FAS500',
    hp: '600',
    price: 'From $7,499',
    href: '/packages/fas500',
    image: '/images/packages/FAS-f150.webp',
    imageLabel: 'FAS500 — Ford F-150',
    featured: false,
    features: [
      'FAS-Spec Twin 54mm Turbo System',
      'Air-to-Air Intercooler + Stainless Plumbing',
      'Upgraded Low-Side Fuel Pump',
      'HP Tuners Calibration (91/93 Octane)',
      'Full In-Shop Install',
    ],
  },
];
---

<section class="pp" aria-labelledby="pp-heading">
  <div class="pp-shell">

    <!-- Header -->
    <div class="pp-header">
      <div class="pp-header-left">
        <div class="pp-kicker">
          <span class="pp-kicker-line" aria-hidden="true"></span>
          <span>Install-Only · FAS Parts · Dyno-Proven</span>
        </div>
        <h2 id="pp-heading" class="pp-title">Power Packages</h2>
        <p class="pp-sub">
          Every package is built with parts we designed and manufactured.
          Every install happens in our shop. Every number gets proven on the
          dyno before your keys come back.
        </p>
      </div>
      <a href="/shop/performance-packages" class="pp-all-link">
        All Packages →
      </a>
    </div>

    <!-- Grid (desktop 3×2) / Deck (mobile) -->
    <div class="pp-grid" id="ppGrid">
      {packages.map((pkg, i) => (
        <div
          class:list={['pp-card', pkg.featured && 'pp-card--featured']}
          data-index={i}
        >
          <!-- Overlay: visible on mobile for non-active cards -->
          <div class="pp-deck-overlay" aria-hidden="true"></div>

          <!-- Visual / image area -->
          <div class="pp-visual">
            {
              pkg.optimizedImage ? (
                <Image
                  src={pkg.optimizedImage}
                  alt={pkg.stage + ' — ' + pkg.platform}
                  class="pp-visual-img"
                  loading="lazy"
                  decoding="async"
                  widths={[360, 540, 720]}
                  sizes="(max-width: 767px) 85vw, (max-width: 1279px) 48vw, 33vw"
                  format="webp"
                />
              ) : (
                <img
                  src={pkg.image}
                  alt={pkg.stage + ' — ' + pkg.platform}
                  class="pp-visual-img"
                  loading="lazy"
                  decoding="async"
                />
              )
            }
            <div class="pp-hp">
              <span class="pp-hp-val">{pkg.hp}</span>
              <span class="pp-hp-unit">HP</span>
            </div>
            <span class="pp-img-label">{pkg.imageLabel}</span>
          </div>

          <!-- Body -->
          <div class="pp-body">
            <span class="pp-platform">{pkg.platform}</span>
            <h3 class="pp-name">{pkg.stage}</h3>

            <ul class="pp-features" aria-label="What's included">
              {pkg.features.map((f) => (
                <li class="pp-feature-item">{f}</li>
              ))}
            </ul>

            <div class="pp-footer">
              <div class="pp-price-wrap">
                <span class="pp-from">Starting From</span>
                <span class="pp-price">{pkg.price}</span>
              </div>
              <a
                href={pkg.href}
                class:list={['pp-btn', pkg.featured && 'pp-btn--featured']}
              >
                Details
              </a>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Mobile swipe hint -->
    <div class="pp-swipe-hint" id="ppSwipeHint" aria-hidden="true">
      <svg class="pp-swipe-icon" width="40" height="22" viewBox="0 0 40 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- left arrow -->
        <path d="M10 11H3M3 11L7 7M3 11L7 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- right arrow -->
        <path d="M30 11H37M37 11L33 7M37 11L33 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- finger -->
        <path d="M20 5V17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="20" cy="18.5" r="1.5" fill="currentColor"/>
      </svg>
      <span>Swipe</span>
    </div>

  </div>
</section>

<style>
  /* ── Shell ── */
  .pp {
    background: var(--bg-base, #09090b);
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .pp-shell {
    width: min(calc(100% - (2 * var(--container-pad-mobile, 20px))), var(--max-w, 1280px));
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .pp-shell {
      width: min(calc(100% - (2 * var(--container-pad-tablet, 32px))), var(--max-w, 1280px));
    }
  }

  @media (min-width: 1024px) {
    .pp-shell {
      width: min(calc(100% - (2 * var(--container-pad-desktop, 72px))), var(--max-w, 1280px));
    }
  }

  /* ── Header ── */
  .pp-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .pp-header-left {
    max-width: 560px;
  }

  .pp-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ff6b6b;
    margin-bottom: 0.75rem;
  }

  .pp-kicker-line {
    display: block;
    width: 28px;
    height: 2px;
    background: #ff6b6b;
    flex-shrink: 0;
  }

  .pp-title {
    font-family: var(--font-display, 'Ethnocentric', sans-serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  .pp-sub {
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: clamp(0.82rem, 1.1vw, 0.95rem);
    color: rgba(220, 224, 236, 0.7);
    line-height: 1.65;
    margin: 0;
    max-width: 50ch;
  }

  .pp-all-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    padding: 0.65rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 3px;
    text-decoration: none;
    white-space: nowrap;
    align-self: flex-start;
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  .pp-all-link:hover {
    border-color: rgba(255, 255, 255, 0.65);
    color: #fff;
  }

  /* ── Grid — always 3 columns at 640px+ ── */
  .pp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .pp-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Deck overlay — hidden on desktop ── */
  .pp-deck-overlay {
    display: none;
  }

  /* ── Swipe hint — hidden on desktop (visible only in mobile media query below) ── */
  .pp-swipe-hint {
    display: none;
  }

  /* ── Card ── */
  .pp-card {
    background: var(--bg-surface, #171717);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }

  .pp-card--featured {
    border-color: rgba(234, 29, 38, 0.45);
    box-shadow: inset 0 0 0 1px rgba(234, 29, 38, 0.12),
                0 0 40px rgba(234, 29, 38, 0.06);
  }

  .pp-card--featured:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(234, 29, 38, 0.3);
  }

  /* ── Visual (image + HP overlay) ── */
  .pp-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #0d0d0f;
    overflow: hidden;
  }

  .pp-visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.55) saturate(0.8);
    transition: filter 0.4s ease, transform 0.5s ease;
  }

  .pp-card:hover .pp-visual img {
    filter: brightness(0.65) saturate(0.9);
    transform: scale(1.03);
  }

  /* Red vignette tint from bottom */
  .pp-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(6, 4, 4, 0.75) 100%
    );
    pointer-events: none;
  }

  /* HP number — top-left overlay */
  .pp-hp {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
    line-height: 1;
  }

  .pp-hp-val {
    display: block;
    font-family: var(--font-display, 'Ethnocentric', sans-serif);
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pp-hp-unit {
    display: block;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ff6b6b;
    margin-top: 2px;
  }

  /* Image caption — bottom-left */
  .pp-img-label {
    position: absolute;
    bottom: 12px;
    left: 14px;
    z-index: 2;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
  }

  /* ── Body ── */
  .pp-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 18px 20px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .pp-platform {
    display: block;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ff6b6b;
    margin-bottom: 5px;
  }

  .pp-name {
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.2;
    margin: 0 0 14px;
  }

  /* ── Feature list ── */
  .pp-features {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .pp-feature-item {
    font-family: var(--font-body, 'Inter', system-ui, sans-serif);
    font-size: 0.78rem;
    color: rgba(220, 224, 236, 0.75);
    line-height: 1.4;
    padding-left: 14px;
    position: relative;
  }

  .pp-feature-item::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--red, #ea1d26);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  /* ── Footer: price + CTA ── */
  .pp-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .pp-price-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pp-from {
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(220, 224, 236, 0.8);
  }

  .pp-price {
    font-family: var(--font-ui, 'Barlow', sans-serif);
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .pp-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-label, 'Barlow Condensed', sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.6rem 1.1rem;
    border-radius: 3px;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    background: transparent;
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s, background 0.2s;
  }

  .pp-btn:hover {
    border-color: rgba(255, 255, 255, 0.65);
  }

  .pp-btn--featured {
    background: var(--red, #ea1d26);
    border-color: var(--red, #ea1d26);
    color: #fff;
  }

  .pp-btn--featured:hover {
    background: #c91820;
    border-color: #c91820;
  }

  /* ═══════════════════════════════════════════════════════════════════════
     MOBILE DECK SWITCHER  (max-width: 639px)
     Cards stack absolutely; JS sets data-deck="0|1|2|back" to position them.
     Clicking a peeking card's overlay brings it to the front.
     Swipe left/right and dot-tap also navigate.
  ═══════════════════════════════════════════════════════════════════════ */
  @media (max-width: 639px) {

    /* Container becomes a fixed-height stacking context (height set by JS) */
    .pp-grid {
      display: block;
      position: relative;
    }

    /* All cards are absolutely layered inside the container */
    .pp-card {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      transition:
        transform 0.42s cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 0.42s ease;
      will-change: transform;
    }

    /* Suppress the desktop lift-on-hover so deck states own the motion */
    .pp-card:hover {
      transform: none;
      box-shadow: none;
    }

    /* ─ Active (front) ─────────────────────────────────── */
    .pp-card[data-deck="0"] {
      transform: translateY(0) scale(1);
      z-index: 30;
      cursor: default;
    }
    .pp-card[data-deck="0"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 44px rgba(0, 0, 0, 0.6);
    }

    /* ─ Peek 1 ──────────────────────────────────────────── */
    .pp-card[data-deck="1"] {
      transform: translateY(18px) scale(0.988);
      z-index: 20;
      cursor: pointer;
    }
    .pp-card[data-deck="1"]:hover {
      transform: translateY(14px) scale(0.988);
    }

    /* ─ Peek 2 ──────────────────────────────────────────── */
    .pp-card[data-deck="2"] {
      transform: translateY(32px) scale(0.976);
      z-index: 10;
      cursor: pointer;
    }
    .pp-card[data-deck="2"]:hover {
      transform: translateY(28px) scale(0.976);
    }

    /* ─ Hidden (behind peek 2) ──────────────────────────── */
    .pp-card[data-deck="back"] {
      transform: translateY(44px) scale(0.964);
      z-index: 5;
      pointer-events: none;
    }

    /* ── Deck overlay ───────────────────────────────────── */
    .pp-deck-overlay {
      display: block;
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: transparent;
      transition: background 0.42s ease;
      /* sits above card content so it can intercept clicks on non-active cards */
      z-index: 40;
    }

    /* Active: invisible + passthrough so Details button stays clickable */
    .pp-card[data-deck="0"] .pp-deck-overlay {
      pointer-events: none;
    }

    /* Peek 1: semi-dark, captures clicks to bring this card forward */
    .pp-card[data-deck="1"] .pp-deck-overlay {
      background: rgba(0, 0, 0, 0.54);
      pointer-events: auto;
      cursor: pointer;
    }

    /* Peek 2: darker */
    .pp-card[data-deck="2"] .pp-deck-overlay {
      background: rgba(0, 0, 0, 0.70);
      pointer-events: auto;
      cursor: pointer;
    }

    /* Hidden: fully dimmed, non-interactive */
    .pp-card[data-deck="back"] .pp-deck-overlay {
      background: rgba(0, 0, 0, 0.84);
      pointer-events: none;
    }

    /* ── Swipe hint ─────────────────────────────────────── */
    .pp-swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 22px;
      color: rgba(255, 255, 255, 0.62);
      transition: opacity 0.6s ease;
      pointer-events: none;
      user-select: none;
    }

    .pp-swipe-hint.pp-swipe-hint--hidden {
      opacity: 0;
    }

    .pp-swipe-icon {
      flex-shrink: 0;
      animation: ppSwipeMotion 2.2s ease-in-out infinite;
    }

    @keyframes ppSwipeMotion {
      0%, 100% { opacity: 0.35; transform: translateX(0); }
      25%       { opacity: 0.6;  transform: translateX(-3px); }
      75%       { opacity: 0.6;  transform: translateX(3px); }
    }

    .pp-swipe-hint span {
      font-family: var(--font-label, 'Barlow Condensed', sans-serif);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.72);
    }
  }
</style>

<script>
  // ── Stagger entrance on scroll ─────────────────────────────────────────
  const ppCards = document.querySelectorAll<HTMLElement>('.pp-card');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.animationPlayState = 'running';
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    ppCards.forEach((c) => io.observe(c));
  }

  // ── Mobile deck switcher ───────────────────────────────────────────────
  ;(function initDeck() {
    const BREAKPOINT = 640;

    const grid      = document.getElementById('ppGrid')      as HTMLElement;
    const swipeHint = document.getElementById('ppSwipeHint') as HTMLElement | null;
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.pp-card'));
    const total = cards.length;

    let hintDismissed = false;

    function hideSwipeHint(): void {
      if (hintDismissed) return;
      hintDismissed = true;
      swipeHint?.classList.add('pp-swipe-hint--hidden');
    }

    let activeIdx  = 0;
    let deckActive = false;
    let touchX0 = 0;
    let touchY0 = 0;

    // ── helpers ──────────────────────────────────────────────────────────

    function isMobile(): boolean {
      return window.innerWidth < BREAKPOINT;
    }

    /** Set container height = active card height + room for peek layers */
    function syncHeight(): void {
      const active = cards[activeIdx];
      if (!active) return;
      grid.style.height = (active.offsetHeight + 50) + 'px';
    }

    /** Assign data-deck positions for all cards */
    function goTo(idx: number): void {
      activeIdx = ((idx % total) + total) % total;

      cards.forEach((card) => {
        const ci  = parseInt(card.dataset.index ?? '0', 10);
        const pos = ((ci - activeIdx) % total + total) % total;
        card.dataset.deck = pos <= 2 ? String(pos) : 'back';
      });

      requestAnimationFrame(syncHeight);
    }

    // ── event handlers ───────────────────────────────────────────────────

    /** Clicking the overlay on a non-active card brings it to front */
    function onOverlayClick(this: HTMLElement): void {
      const card = this.closest<HTMLElement>('.pp-card');
      if (!card) return;
      const ci = parseInt(card.dataset.index ?? '0', 10);
      if (ci !== activeIdx) {
        goTo(ci);
        hideSwipeHint();
      }
    }

    function onTouchStart(e: TouchEvent): void {
      touchX0 = e.touches[0].clientX;
      touchY0 = e.touches[0].clientY;
    }

    function onTouchEnd(e: TouchEvent): void {
      const dx = e.changedTouches[0].clientX - touchX0;
      const dy = e.changedTouches[0].clientY - touchY0;
      // Only count clear horizontal swipes
      if (Math.abs(dy) > Math.abs(dx) || Math.abs(dx) < 32) return;
      goTo(dx < 0 ? activeIdx + 1 : activeIdx - 1);
      hideSwipeHint();
    }

    // ── lifecycle ─────────────────────────────────────────────────────────

    function enableDeck(): void {
      if (deckActive) return;
      deckActive = true;

      goTo(0);

      // Overlays on non-active cards are the click targets
      cards.forEach((card) => {
        card.querySelector<HTMLElement>('.pp-deck-overlay')
          ?.addEventListener('click', onOverlayClick);
      });

      grid.addEventListener('touchstart', onTouchStart, { passive: true });
      grid.addEventListener('touchend',   onTouchEnd,   { passive: true });
    }

    function disableDeck(): void {
      if (!deckActive) return;
      deckActive = false;

      cards.forEach((card) => {
        delete card.dataset.deck;
        card.querySelector<HTMLElement>('.pp-deck-overlay')
          ?.removeEventListener('click', onOverlayClick);
      });

      grid.style.height = '';
      grid.removeEventListener('touchstart', onTouchStart);
      grid.removeEventListener('touchend',   onTouchEnd);
    }

    function checkBreakpoint(): void {
      isMobile() ? enableDeck() : disableDeck();
    }

    // Re-check on viewport resize / orientation change
    const ro = new ResizeObserver(checkBreakpoint);
    ro.observe(document.documentElement);

    checkBreakpoint(); // run immediately on load
  })();
</script>
