---
const packages = [
  // ── Hellcat / Mopar ──────────────────────────────────────────────────────
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS800 — Street Build',
    hp: '800',
    price: 'From $4,299',
    href: '/packages/powerPackages',
    image: '/images/packages/Hellcat/FAS-1.webp',
    imageLabel: 'Hellcat FAS800 — Punta Gorda shop build',
    featured: false,
    features: [
      'FAS Upper Pulley Kit',
      'Upgraded Spark Plugs + 180° Thermostat',
      'FAS Custom Engine & Trans Tune',
      'Full In-Shop Install',
    ],
  },
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS1000 — Race Ready',
    hp: '1000',
    price: 'From $9,999',
    href: '/packages/powerPackages',
    image: '/images/packages/Hellcat/FAS-fas-1000-challenger.webp',
    imageLabel: 'Hellcat FAS1000 — Punta Gorda shop build',
    featured: true,
    features: [
      'Race-Ported Supercharger',
      '108mm Throttle Body + High-Flow Intake',
      'Longtube Headers + Race Midpipes',
      'E85 Fuel System + ID Injectors',
      'Custom Dyno Tune — Full Install',
    ],
  },
  {
    platform: 'Dodge Challenger / Charger SRT',
    stage: 'FAS 1X — 1200–1500 HP',
    hp: '1500',
    price: 'Call for Pricing',
    href: '/packages/powerPackages',
    image: '/images/packages/Hellcat/FAS-4.webp',
    imageLabel: 'Hellcat 1X build — Punta Gorda shop build',
    featured: false,
    features: [
      '1200–1500 HP Custom Program',
      'Short-Block + Valvetrain Upgrades',
      '3.0 Upper / 9.1 Lower Pulley Combo',
      'Fore Triple-Pump Fuel System',
      'Consultation-Driven Build',
    ],
  },
  // ── RAM TRX ──────────────────────────────────────────────────────────────
  {
    platform: 'RAM TRX',
    stage: 'FAS800 — Stage 2',
    hp: '800',
    price: 'From $6,699',
    href: '/packages/truckPackages',
    image: '/images/packages/FAS-TRX-build1.webp',
    imageLabel: 'RAM TRX FAS800 — Punta Gorda shop build',
    featured: false,
    features: [
      'FAS Upper Pulley Kit + Billet Idler',
      'Upgraded Spark Plugs + 180° Thermostat',
      'FAS Custom Engine & Trans Tune',
      'Full In-Shop Install',
    ],
  },
  {
    platform: 'RAM TRX',
    stage: 'FAS1000 — Stage 4',
    hp: '1000',
    price: 'From $17,999',
    href: '/shop/fas-factory-freak-package-trx',
    image: '/images/packages/D-FAS-TRX-Package.webp',
    imageLabel: 'RAM TRX FAS1000 — Punta Gorda shop build',
    featured: false,
    features: [
      'Full Race-Ported Supercharger',
      'Long-Tube Headers + Race Midpipes',
      'Fore Dual-Pump Return Fuel System',
      'Dedicated E85 / VP Tune',
      'Full In-Shop Install',
    ],
  },
  // ── Ford F-150 ───────────────────────────────────────────────────────────
  {
    platform: 'Ford F-150 (2018+)',
    stage: 'FAS500 — Twin Turbo Street',
    hp: '600',
    price: 'From $7,499',
    href: '/packages/truckPackages',
    image: '/images/packages/FAS-f150-10002.webp',
    imageLabel: 'Ford F-150 Twin Turbo — Punta Gorda shop build',
    featured: false,
    features: [
      'FAS-Spec Twin 54mm Turbo System',
      'Air-to-Air Intercooler + Stainless Plumbing',
      'Upgraded Low-Side Fuel Pump',
      'HP Tuners Calibration (91/93 Octane)',
      'Full In-Shop Install',
    ],
  },
