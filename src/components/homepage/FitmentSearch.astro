<section class="homepage-fitment">
  <div class="homepage-shell homepage-fitment-inner">
    <div>
      <div class="homepage-kicker">
        <span class="homepage-kicker-line"></span>
        <span>Find Your Fit</span>
      </div>
      <h2 class="homepage-section-title">Shop Parts for Your Exact Build</h2>
      <p class="homepage-section-copy">
        Select your year, make, and model to filter parts that fit your exact build — no guessing on compatibility.
      </p>
    </div>

    <form class="homepage-fitment-form" action="/shop/storefront" method="get">
      <select name="year" aria-label="Select year">
        <option value="">Year</option>
        <option>2024</option>
        <option>2023</option>
        <option>2022</option>
        <option>2021</option>
        <option>2020</option>
      </select>
      <select name="make" aria-label="Select make">
        <option value="">Make</option>
        <option>Dodge</option>
        <option>Ram</option>
        <option>Ford</option>
        <option>Chevrolet</option>
      </select>
      <select name="model" aria-label="Select model">
        <option value="">Model</option>
        <option>Charger Hellcat</option>
        <option>Challenger Hellcat</option>
        <option>Ram 1500 TRX</option>
        <option>F-150 Raptor</option>
        <option>Camaro ZL1</option>
      </select>
      <button type="submit" class="homepage-btn homepage-btn-primary">Search</button>
    </form>
  </div>
</section>
