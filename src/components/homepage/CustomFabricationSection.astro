---
import { Image } from 'astro:assets';
import img_custfabrication from '@/assets/images/fabrication/custFabrication.webp';
---

<section class="homepage-section">
  <div class="homepage-shell homepage-fab-grid">
    <div>
      <div class="homepage-kicker">
        <span class="homepage-kicker-line"></span>
        <span>In-House</span>
      </div>
      <h2 class="homepage-section-title">Custom Fabrication</h2>
      <p class="homepage-section-copy">
        304 and 316L stainless work, TIG welded and fitted in-house. Exhaust, headers, intake
        fabrication, tow hooks, and one-off solutions are still a core part of the shop.
      </p>
      <div class="homepage-fab-specs">
        <div><span>Material</span><strong>304 / 316L Stainless</strong></div>
        <div><span>Process</span><strong>TIG Welded</strong></div>
        <div><span>Lead Time</span><strong>5-10 Business Days</strong></div>
        <div><span>Location</span><strong>Punta Gorda, FL</strong></div>
      </div>
      <div class="homepage-button-row">
        <a href="/services/customFab" class="homepage-btn homepage-btn-primary"
          >Learn More</a
        >
        <a href="/services/customFab/inquiry" class="homepage-btn homepage-btn-secondary">Custom Fab Inquiry</a>
      </div>
    </div>

    <div class="homepage-fab-visual" aria-hidden="true">
      <Image
        src={img_custfabrication}
        alt=""
        class="homepage-fab-visual-img"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
