---
import { Image } from 'astro:assets';
import img_trx_hellcat from '@/assets/images/backgrounds/trx-hellcat.jpg';
---
<section class="homepage-hero" aria-labelledby="homepage-hero-title">
  {/* Right-side visual — absolutely positioned, fills right half, fades left */}
  <div class="homepage-hero-visual" aria-hidden="true">
    <Image
      src={img_trx_hellcat}
      alt=""
      class="homepage-hero-visual-img"
      loading="eager"
      fetchpriority="high"
      widths={[400, 640, 900, 1200, 1600]}
      sizes="(max-width: 768px) 100vw, 52vw"
      format="webp"
      quality={80}
    />
    <div class="homepage-hero-visual-label">TRX / Hellcat Feature Build</div>
  </div>

  {/* Content column — shell constrains width, z-index above visual */}
  <div class="homepage-shell homepage-hero-content">
    <div class="homepage-hero-copy">
      <div class="homepage-kicker">
        <span class="homepage-kicker-line"></span>
        <span>Punta Gorda, FL · Est. 2002</span>
      </div>
      <h1 id="homepage-hero-title" class="homepage-hero-title">
        Supercharger
        <br />
        Porting &amp;
        <br />
        <span>Performance.</span>
      </h1>
      <p class="homepage-hero-subcopy">
        Three generations of racing and fabrication, now focused on billet parts, in-house installs,
        and validated power packages for the builds that actually get driven hard.
      </p>
      <div class="homepage-button-row">
        <a href="/shop/categories/billet-parts" class="homepage-btn homepage-btn-primary"
          >Shop Billet Parts</a
        >
        <a href="/shop/performance-packages" class="homepage-btn homepage-btn-secondary"
          >View Packages</a
        >
      </div>
    </div>

    <div class="homepage-hero-stats" aria-label="FAS Motorsports at a glance">
      <div>
        <strong>50+</strong>
        <span>Years Combined</span>
      </div>
      <div>
        <strong>500+</strong>
        <span>Builds</span>
      </div>
      <div>
        <strong>1,500+</strong>
        <span>Horsepower</span>
      </div>
      <div>
        <strong>2002</strong>
        <span>Since</span>
      </div>
    </div>
  </div>
</section>
