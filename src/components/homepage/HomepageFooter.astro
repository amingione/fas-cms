---
import { BUSINESS_PHONE_E164, BUSINESS_PHONE_NATIONAL } from '@/lib/nap';
---

<footer class="fas-footer">
  <div class="homepage-shell">
    <div class="fas-footer-grid">
      <!-- Brand + Contact -->
      <div>
        <div class="fas-footer-brandmark">
          <span class="fas-footer-fas">FAS</span>
          <span class="fas-footer-moto">Motorsports</span>
        </div>
        <div class="fas-footer-tagline">
          <strong>Fast</strong> · <strong>Aggressive</strong> · <strong>Superior</strong>
        </div>
        <p class="fas-footer-about">
          Three generations of performance. One standard: build it right or don't build it at all.
          Punta Gorda, Florida — Est. 2002.
        </p>
        <div class="fas-footer-contact">
          <a href={`tel:${BUSINESS_PHONE_E164}`}>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.89.35 1.82.58 2.81.7A2 2 0 0122 14.92z"
              ></path>
            </svg>
            {BUSINESS_PHONE_NATIONAL}
          </a>
          <a href="mailto:sales@fasmotorsports.com">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            sales@fasmotorsports.com
          </a>
          <span>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            Punta Gorda, Florida
          </span>
        </div>
      </div>

      <!-- Shop -->
      <div class="fas-footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/shop/categories/billet-parts/">Billet Parts</a></li>
          <li><a href="/shop/performance-packages">Performance Packages</a></li>
          <li><a href="/wheels">Wheels</a></li>
          <li><a href="/shop">All Products</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="fas-footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services/customFab">Custom Fabrication</a></li>
          <li><a href="/services/porting">Porting</a></li>
          <li><a href="/services/overview">All Services</a></li>
          <li><a href="/contact">Schedule Service</a></li>
        </ul>
      </div>

      <!-- Account -->
      <div class="fas-footer-col">
        <h4>Account</h4>
        <ul>
          <li><a href="/vendor-portal/login">Vendor Portal</a></li>
          <li><a href="/become-a-vendor">Dealer Application</a></li>
          <li><a href="/about">About FAS</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="fas-footer-bottom">
      <div class="fas-footer-legal">
        © 2026 FAS Motorsports. All rights reserved. Punta Gorda, FL.
      </div>
      <div class="fas-footer-social" aria-label="Follow FAS Motorsports">
        <a
          href="https://instagram.com/fas_moto"
          class="fas-social-btn"
          aria-label="FAS on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/fasmotorsportsfl"
          class="fas-social-btn"
          aria-label="FAS on Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            aria-hidden="true"
          >
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
