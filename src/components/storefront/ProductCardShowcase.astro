---
import ProductQuickViewButton from '@/components/storefront/ProductQuickViewButton.tsx';
import Price from '@/components/storefront/Price.tsx';
import { portableTextToPlainText } from '@/lib/portableText.ts';
import { normalizeSlugValue, resolveSanityImageUrl, buildSanitySrcSet } from '@/lib/sanity-utils.ts';
import { getQuickViewOptionGroups } from '@/lib/quick-view-options.ts';
import { resolveProductCartMeta } from '@/lib/product-flags.ts';
import { getSaleBadgeText, isOnSale } from '@/lib/saleHelpers.ts';
import {
  resolveProductCalculatedOriginalAmount,
  resolveProductCalculatedPriceAmount,
  resolveProductMedusaVariant
} from '@/lib/medusa-storefront-pricing';

interface ImgAsset {
  url?: string;
}
interface Img {
  asset?: ImgAsset;
  alt?: string;
}
interface Slug {
  current?: string;
}

const {
  product,
  productImage,
  layout = 'grid',
  showQuickView = true
} = Astro.props as {
  product: {
    _id: string;
    title?: string;
    displayTitle?: string;
    slug?: Slug | string;
    images?: Img[];
    shortDescription?: string;
    description?: string;
    excerpt?: string;
    summary?: string;
    brand?: string;
    fitment?: string;
    fitmentRange?: string;
    saleLabel?: string;
    featured?: boolean;
    categories?: Array<{ title?: string }>;
    compatibleVehicles?: Array<{ make?: string; model?: string; trim?: string }>;
    shippingClass?: string;
    productType?: string;
  };
  productImage?: Img;
  layout?: 'grid' | 'list';
  showQuickView?: boolean;
};

const slug = normalizeSlugValue((product as any)?.slug);
const href = slug ? `/shop/${encodeURIComponent(slug)}` : '#';
const fallbackImage = '/logo/fas-logo500.webp';
const img = resolveSanityImageUrl([productImage, product?.images]) ?? fallbackImage;
const imgSrcSet = buildSanitySrcSet(img, { widths: [400, 600, 900, 1200] });
const baseTitle = (product as any)?.displayTitle || product?.title || 'Untitled Product';
const anchorText =
  typeof (product as any)?.seoAnchorText === 'string' &&
  (product as any).seoAnchorText.trim().length > 0
    ? (product as any).seoAnchorText.trim()
    : baseTitle;
const short =
  portableTextToPlainText((product as any)?.shortDescription) ||
  portableTextToPlainText((product as any)?.description) ||
  (product as any)?.excerpt ||
  (product as any)?.summary ||
  '';
const shortText = typeof short === 'string' ? short.trim() : '';
const quickViewOptions = getQuickViewOptionGroups(product);
const price = resolveProductCalculatedPriceAmount(product) ?? undefined;
const compareAt = resolveProductCalculatedOriginalAmount(product) ?? undefined;
const medusaVariant = resolveProductMedusaVariant(product) as Record<string, any> | null;
const onSale = typeof price === 'number' && typeof compareAt === 'number' && compareAt > price;
const saleBadge = getSaleBadgeText(product as any);
const { installOnly } = resolveProductCartMeta(product as any);
const analyticsParams = JSON.stringify(
  Object.fromEntries(
    Object.entries({
      product_id: typeof product?._id === 'string' ? product._id : undefined,
      product_name: baseTitle,
      product_slug: slug || undefined,
      price,
      tile_layout: layout,
      tile_style: 'showcase'
    }).filter(([, value]) => value !== undefined && value !== null && value !== '')
  )
);
const shippingConfig = (product as any)?.shippingConfig || (product as any)?.shipping_config;
const shippingWeight =
  typeof shippingConfig?.weight === 'number' ? shippingConfig.weight : undefined;
const shippingDimensions =
  shippingConfig?.dimensions && typeof shippingConfig.dimensions === 'object'
    ? {
        length:
          typeof shippingConfig.dimensions.length === 'number'
            ? shippingConfig.dimensions.length
            : undefined,
        width:
          typeof shippingConfig.dimensions.width === 'number'
            ? shippingConfig.dimensions.width
            : undefined,
        height:
          typeof shippingConfig.dimensions.height === 'number'
            ? shippingConfig.dimensions.height
            : undefined
      }
    : undefined;

const resolveEyebrow = (value: typeof product) => {
  if (typeof value?.brand === 'string' && value.brand.trim()) return value.brand.trim();
  if (Array.isArray(value?.categories) && typeof value.categories[0]?.title === 'string') {
    return value.categories[0].title.trim();
  }
  return 'FAS Motorsports';
};

const resolveVehicleText = (value: typeof product) => {
  if (typeof value?.fitmentRange === 'string' && value.fitmentRange.trim()) return value.fitmentRange.trim();
  if (typeof value?.fitment === 'string' && value.fitment.trim()) return value.fitment.trim();
  if (Array.isArray(value?.compatibleVehicles) && value.compatibleVehicles.length > 0) {
    const firstVehicle = value.compatibleVehicles[0];
    const parts = [firstVehicle?.make, firstVehicle?.model, firstVehicle?.trim].filter(
      (item): item is string => typeof item === 'string' && item.trim().length > 0
    );
    if (parts.length > 0) return parts.join(' ');
  }
  return shortText;
};

const resolveBadge = () => {
  if (saleBadge) return { label: saleBadge, tone: 'sale' as const };
  if (installOnly) return { label: 'Install Only', tone: 'neutral' as const };
  if (isOnSale(product as any)) return { label: 'Sale', tone: 'sale' as const };
  if ((product as any)?.featured === true) return { label: 'Featured', tone: 'primary' as const };
  return null;
};

const resolveInventory = () => {
  const manageInventory = Boolean((medusaVariant as any)?.manage_inventory);
  const allowBackorder = Boolean((medusaVariant as any)?.allow_backorder);
  const quantity = typeof (medusaVariant as any)?.inventory_quantity === 'number'
    ? Number((medusaVariant as any).inventory_quantity)
    : null;

  if (!manageInventory) return { label: 'In stock', tone: 'stock' as const };
  if (typeof quantity === 'number' && quantity > 3) return { label: 'In stock', tone: 'stock' as const };
  if (typeof quantity === 'number' && quantity > 0) return { label: 'Low stock', tone: 'low' as const };
  if (allowBackorder) return { label: 'Backorder', tone: 'neutral' as const };
  return { label: 'Out of stock', tone: 'sale' as const };
};

const eyebrow = resolveEyebrow(product);
const vehicleText = resolveVehicleText(product);
const badge = resolveBadge();
const inventory = resolveInventory();
const ctaText = installOnly ? 'View Build Details' : 'View Product';
---

{
  layout === 'list' ? (
    <article class="group relative">
      <a
        href={href}
        class="group flex h-full flex-col overflow-hidden rounded-card border border-white/10 bg-[linear-gradient(180deg,rgba(24,24,24,0.96),rgba(10,10,10,0.98))] shadow-product-hover transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-0.5 hover:border-primary/50 hover:shadow-product-hover focus:outline-none focus:ring-2 focus:ring-primary md:flex-row md:items-stretch"
        data-analytics-event="product_tile_click"
        data-analytics-category="ecommerce"
        data-analytics-label={anchorText}
        data-analytics-params={analyticsParams}
      >
        <div class="relative isolate flex aspect-[1/1] min-h-[260px] items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_top,rgba(196,18,24,0.16),transparent_55%),linear-gradient(180deg,rgba(28,28,28,0.98),rgba(16,16,16,0.98))] px-8 py-10 md:min-h-full md:w-[280px] md:min-w-[280px]">
          <div class="absolute inset-0 bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.03),transparent)] opacity-60"></div>
          {
            badge && (
              <span
                class:list={[
                  'absolute left-5 top-5 z-[1] inline-flex min-h-[34px] items-center rounded-sm px-4 text-[0.72rem] font-semibold uppercase tracking-[0.22em]',
                  badge.tone === 'sale'
                    ? 'bg-primary text-white'
                    : badge.tone === 'primary'
                      ? 'bg-primary text-white'
                      : 'bg-white text-black'
                ]}
              >
                {badge.label}
              </span>
            )
          }
          <img
            src={img}
            srcset={imgSrcSet}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 40vw"
            alt={anchorText}
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            referrerpolicy="strict-origin-when-cross-origin"
            draggable="false"
            class="relative z-[1] max-h-[84%] max-w-[88%] object-contain transition-transform duration-300 ease-out group-hover:scale-[1.04]"
          />
        </div>

        <div class="flex min-w-0 flex-1 flex-col">
          <div class="border-y border-white/5 bg-black/80 px-6 py-4 text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-primary">
            {ctaText}
          </div>
          <div class="flex min-h-0 flex-1 flex-col px-6 py-6">
            <div class="text-[0.75rem] font-semibold uppercase tracking-[0.26em] text-primary">{eyebrow}</div>
            <h3 class="mt-4 text-[1.5rem] font-semibold leading-tight text-white">
              {anchorText}
            </h3>
            {
              vehicleText && (
                <p class="mt-3 text-sm leading-7 text-white/45">{vehicleText}</p>
              )
            }
            <div class="mt-auto flex items-end justify-between gap-4 pt-8">
              <div>
                {
                  typeof price === 'number' ? (
                    <Price
                      amount={price}
                      originalAmount={compareAt}
                      onSale={onSale}
                      className="text-[2rem] font-semibold leading-none text-white"
                    />
                  ) : (
                    <span class="text-sm font-semibold uppercase tracking-[0.18em] text-white/55">Unavailable</span>
                  )
                }
              </div>
              <div
                class:list={[
                  'inline-flex items-center gap-2 text-[0.78rem] font-semibold uppercase tracking-[0.18em]',
                  inventory.tone === 'stock'
                    ? 'text-emerald-400'
                    : inventory.tone === 'low'
                      ? 'text-amber-400'
                      : inventory.tone === 'sale'
                        ? 'text-primary'
                        : 'text-white/60'
                ]}
              >
                <span class="h-2.5 w-2.5 rounded-full bg-current"></span>
                <span>{inventory.label}</span>
              </div>
            </div>
          </div>
        </div>
      </a>
      {
        showQuickView && (
          <div class="pointer-events-none absolute right-4 top-4 z-10 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100">
            <ProductQuickViewButton
              client:idle
              className="pointer-events-auto"
              product={{
                id: typeof product?._id === 'string' ? product._id : undefined,
                title: baseTitle,
                href,
                price,
                stripePriceId: (product as any)?.stripePriceId,
                medusaVariantId:
                  (product as any)?.medusaVariantId ||
                  (typeof (medusaVariant as any)?.id === 'string'
                    ? (medusaVariant as any).id
                    : undefined),
                imageSrc: img,
                imageAlt: anchorText,
                description: shortText,
                shortDescriptionPortable: (product as any)?.shortDescription,
                shippingWeight,
                shippingDimensions,
                optionGroups: quickViewOptions
              }}
            />
          </div>
        )
      }
    </article>
  ) : (
    <article class="group relative h-full">
      <a
        href={href}
        class="group flex h-full flex-col overflow-hidden rounded-card border border-white/10 bg-[linear-gradient(180deg,rgba(23,23,23,0.98),rgba(10,10,10,0.98))] shadow-product-hover transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-primary/55 hover:shadow-product-hover focus:outline-none focus:ring-2 focus:ring-primary"
        data-analytics-event="product_tile_click"
        data-analytics-category="ecommerce"
        data-analytics-label={anchorText}
        data-analytics-params={analyticsParams}
      >
        <div class="relative isolate flex aspect-[0.96/1] items-center justify-center overflow-hidden bg-[radial-gradient(circle_at_top,rgba(196,18,24,0.16),transparent_55%),linear-gradient(180deg,rgba(28,28,28,0.98),rgba(16,16,16,0.98))] px-7 py-10">
          <div class="absolute inset-0 bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.03),transparent)] opacity-70"></div>
          {
            badge && (
              <span
                class:list={[
                  'absolute left-5 top-5 z-[1] inline-flex min-h-[34px] items-center rounded-sm px-4 text-[0.72rem] font-semibold uppercase tracking-[0.22em]',
                  badge.tone === 'sale'
                    ? 'bg-primary text-white'
                    : badge.tone === 'primary'
                      ? 'bg-primary text-white'
                      : 'bg-white text-black'
                ]}
              >
                {badge.label}
              </span>
            )
          }
          <img
            src={img}
            srcset={imgSrcSet}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 40vw"
            alt={anchorText}
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            referrerpolicy="strict-origin-when-cross-origin"
            draggable="false"
            class="relative z-[1] max-h-[78%] max-w-[85%] object-contain transition-transform duration-300 ease-out group-hover:scale-[1.04]"
          />
        </div>

        <div class="border-t border-white/5 bg-black px-6 py-4 text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-primary">
          <span class="inline-flex items-center gap-3">
            <span class="text-[1.2rem] leading-none">+</span>
            <span>{ctaText}</span>
          </span>
        </div>

        <div class="flex flex-1 flex-col bg-[linear-gradient(180deg,rgba(14,14,14,0.94),rgba(10,10,10,0.98))] px-6 py-6">
          <div class="text-[0.75rem] font-semibold uppercase tracking-[0.26em] text-primary">{eyebrow}</div>
          <h3 class="mt-4 text-[1.15rem] font-semibold leading-tight text-white">
            {anchorText}
          </h3>
          {
            vehicleText && (
              <p class="mt-4 text-sm leading-7 text-white/40">
                {vehicleText}
              </p>
            )
          }

          <div class="mt-auto flex items-end justify-between gap-4 pt-8">
            <div class="min-w-0">
              {
                typeof price === 'number' ? (
                  <Price
                    amount={price}
                    originalAmount={compareAt}
                    onSale={onSale}
                    className="text-[2rem] font-semibold leading-none text-white"
                  />
                ) : (
                  <span class="text-sm font-semibold uppercase tracking-[0.18em] text-white/55">Unavailable</span>
                )
              }
            </div>
            <div
              class:list={[
                'shrink-0 inline-flex items-center gap-2 text-[0.78rem] font-semibold uppercase tracking-[0.18em]',
                inventory.tone === 'stock'
                  ? 'text-emerald-400'
                  : inventory.tone === 'low'
                    ? 'text-amber-400'
                    : inventory.tone === 'sale'
                      ? 'text-primary'
                      : 'text-white/60'
              ]}
            >
              <span class="h-2.5 w-2.5 rounded-full bg-current"></span>
              <span>{inventory.label}</span>
            </div>
          </div>
        </div>
      </a>
      {
        showQuickView && (
          <div class="pointer-events-none absolute right-4 top-4 z-10 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100">
            <ProductQuickViewButton
              client:idle
              className="pointer-events-auto"
              product={{
                id: typeof product?._id === 'string' ? product._id : undefined,
                title: baseTitle,
                href,
                price,
                stripePriceId: (product as any)?.stripePriceId,
                medusaVariantId:
                  (product as any)?.medusaVariantId ||
                  (typeof (medusaVariant as any)?.id === 'string'
                    ? (medusaVariant as any).id
                    : undefined),
                imageSrc: img,
                imageAlt: anchorText,
                description: shortText,
                shortDescriptionPortable: (product as any)?.shortDescription,
                shippingWeight,
                shippingDimensions,
                optionGroups: quickViewOptions
              }}
            />
          </div>
        )
      }
    </article>
  )
}
