---
type FaqItem = {
  question: string;
  answer: string;
};

const {
  title = 'Storefront FAQs',
  subtitle,
  items = []
} = Astro.props as {
  title?: string;
  subtitle?: string;
  items?: FaqItem[];
};

const safeItems = Array.isArray(items)
  ? items.filter(
      (item): item is FaqItem =>
        Boolean(item) &&
        typeof item.question === 'string' &&
        item.question.trim().length > 0 &&
        typeof item.answer === 'string' &&
        item.answer.trim().length > 0
    )
  : [];
---

{
  safeItems.length > 0 && (
    <section class="mx-auto mt-16 w-full max-w-6xl px-4 pb-8 md:px-8" aria-label={title}>
      <div class="rounded-xl border border-white/15 bg-dark/40 p-5 md:p-8">
        <h2 class="text-2xl font-ethno text-white md:text-3xl">{title}</h2>
        {subtitle && <p class="mt-2 text-sm text-white/75 md:text-base">{subtitle}</p>}
        <dl class="mt-6 space-y-4">
          {safeItems.map((item) => (
            <div class="rounded-lg border border-white/10 bg-dark/40 p-4">
              <dt class="text-base font-semibold text-white">{item.question}</dt>
              <dd class="mt-2 text-sm leading-relaxed text-white/80 md:text-base">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )
}
